<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════════
         REVIT PLUGIN SHARED STYLE GUIDE  —  Navy Corporate Theme
         Version : 3.0
         Drop-in compatible with v2.1 key names; adds DataGrid,
         header bar, badge, and button-variant styles for reuse
         across all 10 tools.
    ═══════════════════════════════════════════════════════════ -->

    <!-- ─── FONT FAMILY ───────────────────────────────────────── -->
    <FontFamily x:Key="SystemFont">Segoe UI, -apple-system, BlinkMacSystemFont, Helvetica Neue, sans-serif</FontFamily>

    <!-- ═══════════════════════════════════════════════════════════
         COLOR TOKENS — Navy Corporate Palette
    ═══════════════════════════════════════════════════════════ -->

    <!-- Backgrounds -->

    <Color x:Key="SystemBackground">LightBlue</Color>
    <Color x:Key="SystemSecondaryBackground">#EEF3F9</Color>
    <Color x:Key="SystemTertiaryBackground">#DCE6F2</Color>
    <Color x:Key="SeparatorColor">#D7E1ED</Color>
    <Color x:Key="SeparatorThin">#E8EEF6</Color>

    <!-- Brand / Accent -->
    <Color x:Key="NavyPrimary">#1E3A5F</Color>
    <Color x:Key="NavyDark">#14283F</Color>
    <Color x:Key="NavyLight">#2C4A6E</Color>
    <Color x:Key="AppleBlue">#2D6CDF</Color>
    <!-- kept key name for backward compatibility -->
    <Color x:Key="AppleBlueLight">#5B8DEF</Color>
    <Color x:Key="AppleBlueDark">#1E4FB8</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#1A2B3C</Color>
    <Color x:Key="TextSecondary">#5B7185</Color>
    <Color x:Key="TextTertiary">#8FA3B8</Color>
    <Color x:Key="TextDisabled">#C3CFDB</Color>
    <Color x:Key="TextOnDark">#EAF1F8</Color>

    <!-- Status -->
    <Color x:Key="ColorSuccess">#2E9E64</Color>
    <Color x:Key="ColorWarning">#E0922E</Color>
    <Color x:Key="ColorDanger">#D9534F</Color>
    <Color x:Key="ColorInfo">#2D6CDF</Color>

    <!-- Log Panel (always dark, regardless of window theme) -->
    <Color x:Key="LogBackground">#14283F</Color>
    <Color x:Key="LogTitleBar">#1E3A5F</Color>
    <Color x:Key="LogText">#EAF1F8</Color>
    <Color x:Key="LogTextDim">#7E94AA</Color>
    <Color x:Key="LogSuccess">#4CC18A</Color>
    <Color x:Key="LogWarning">#F0AE5C</Color>
    <Color x:Key="LogError">#F0837D</Color>
    <Color x:Key="LogHighlight">#7FB0FF</Color>

    <!-- Cards -->
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="CardBorder">#D7E1ED</Color>
    <Color x:Key="IconTint">#5B7185</Color>

    <!-- ═══════════════════════════════════════════════════════════
         SOLID COLOR BRUSHES
    ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="BrushSystemBackground"          Color="{StaticResource SystemBackground}"/>
    <SolidColorBrush x:Key="BrushSystemSecondaryBackground" Color="{StaticResource SystemSecondaryBackground}"/>
    <SolidColorBrush x:Key="BrushSystemTertiaryBackground"  Color="{StaticResource SystemTertiaryBackground}"/>
    <SolidColorBrush x:Key="BrushSeparator"                 Color="{StaticResource SeparatorColor}"/>
    <SolidColorBrush x:Key="BrushSeparatorThin"             Color="{StaticResource SeparatorThin}"/>

    <SolidColorBrush x:Key="BrushNavyPrimary"               Color="{StaticResource NavyPrimary}"/>
    <SolidColorBrush x:Key="BrushNavyDark"                  Color="{StaticResource NavyDark}"/>
    <SolidColorBrush x:Key="BrushNavyLight"                 Color="{StaticResource NavyLight}"/>
    <SolidColorBrush x:Key="BrushAppleBlue"                 Color="{StaticResource AppleBlue}"/>
    <SolidColorBrush x:Key="BrushAppleBlueLight"            Color="{StaticResource AppleBlueLight}"/>
    <SolidColorBrush x:Key="BrushAppleBlueDark"             Color="{StaticResource AppleBlueDark}"/>

    <SolidColorBrush x:Key="BrushTextPrimary"               Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="BrushTextSecondary"             Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="BrushTextTertiary"              Color="{StaticResource TextTertiary}"/>
    <SolidColorBrush x:Key="BrushTextDisabled"              Color="{StaticResource TextDisabled}"/>
    <SolidColorBrush x:Key="BrushTextOnDark"                Color="{StaticResource TextOnDark}"/>

    <SolidColorBrush x:Key="BrushSuccess"                   Color="{StaticResource ColorSuccess}"/>
    <SolidColorBrush x:Key="BrushWarning"                   Color="{StaticResource ColorWarning}"/>
    <SolidColorBrush x:Key="BrushDanger"                    Color="{StaticResource ColorDanger}"/>
    <SolidColorBrush x:Key="BrushInfo"                      Color="{StaticResource ColorInfo}"/>

    <SolidColorBrush x:Key="BrushLogBg"                     Color="{StaticResource LogBackground}"/>
    <SolidColorBrush x:Key="BrushLogTitleBar"               Color="{StaticResource LogTitleBar}"/>
    <SolidColorBrush x:Key="BrushLogText"                   Color="{StaticResource LogText}"/>
    <SolidColorBrush x:Key="BrushLogTextDim"                Color="{StaticResource LogTextDim}"/>
    <SolidColorBrush x:Key="BrushLogSuccess"                Color="{StaticResource LogSuccess}"/>
    <SolidColorBrush x:Key="BrushLogWarning"                Color="{StaticResource LogWarning}"/>
    <SolidColorBrush x:Key="BrushLogError"                  Color="{StaticResource LogError}"/>
    <SolidColorBrush x:Key="BrushLogHighlight"              Color="{StaticResource LogHighlight}"/>

    <SolidColorBrush x:Key="BrushCardBackground"            Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="BrushCardBorder"                Color="{StaticResource CardBorder}"/>
    <SolidColorBrush x:Key="BrushIconTint"                  Color="{StaticResource IconTint}"/>

    
    <!-- ═══════════════════════════════════════════════════════════
         TYPOGRAPHY — sizes nudged up for readability
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="AppName" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
    </Style>

    <Style x:Key="AppSubtitle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="11.5"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        <Setter Property="Margin"     Value="0,2,0,0"/>
    </Style>

    <!-- Section headers: navy + letter-spacing feel via uppercase, used above each card -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="11.5"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Foreground"   Value="{StaticResource BrushNavyPrimary}"/>
        <Setter Property="Margin"       Value="12,10,12,5"/>
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="11.5"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        <Setter Property="Margin"     Value="0,0,0,2"/>
    </Style>

    <Style x:Key="FieldValue" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="13.5"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
    </Style>

    <Style x:Key="HintText" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="10.5"/>
        <Setter Property="Foreground"   Value="{StaticResource BrushTextTertiary}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin"       Value="0,3,0,0"/>
    </Style>

    <Style x:Key="UnitLabel" TargetType="TextBlock">
        <Setter Property="FontSize"           Value="12"/>
        <Setter Property="Foreground"         Value="{StaticResource BrushTextTertiary}"/>
        <Setter Property="VerticalAlignment"  Value="Center"/>
        <Setter Property="Margin"             Value="3,0,0,0"/>
    </Style>

    <!-- Generic body text — for any plain TextBlock needing the readable default -->
    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="13"/>
        <Setter Property="Foreground"   Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         METRIC STYLES
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="MetricValue" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushNavyPrimary}"/>
    </Style>

    <Style x:Key="MetricLabel" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="10.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        <Setter Property="Margin"     Value="0,0,0,5"/>
    </Style>

    <!-- Large metric number — base style, navy by default -->
    <Style x:Key="MetricNumber" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="23"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushNavyPrimary}"/>
    </Style>

    <!-- Semantic variants — use instead of hardcoded named colors (Orange, Cyan, etc.) -->
    <Style x:Key="MetricNumberAccent" TargetType="TextBlock" BasedOn="{StaticResource MetricNumber}">
        <Setter Property="Foreground" Value="{StaticResource BrushAppleBlue}"/>
    </Style>

    <Style x:Key="MetricNumberSuccess" TargetType="TextBlock" BasedOn="{StaticResource MetricNumber}">
        <Setter Property="Foreground" Value="{StaticResource BrushSuccess}"/>
    </Style>

    <Style x:Key="MetricNumberWarning" TargetType="TextBlock" BasedOn="{StaticResource MetricNumber}">
        <Setter Property="Foreground" Value="{StaticResource BrushWarning}"/>
    </Style>

    <Style x:Key="MetricNumberDanger" TargetType="TextBlock" BasedOn="{StaticResource MetricNumber}">
        <Setter Property="Foreground" Value="{StaticResource BrushDanger}"/>
    </Style>

    <Style x:Key="MetricUnit" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="10.5"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextTertiary}"/>
        <Setter Property="Margin"     Value="0,3,0,0"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         HEADER BAR — navy bar for window/app identity
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="HeaderBar" TargetType="Border">
        <Setter Property="Background"   Value="{StaticResource BrushNavyPrimary}"/>
        <Setter Property="CornerRadius" Value="10,10,0,0"/>
        <Setter Property="Padding"      Value="16,12"/>
    </Style>

    <Style x:Key="HeaderTitle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextOnDark}"/>
    </Style>

    <Style x:Key="HeaderSubtitle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="11.5"/>
        <Setter Property="Foreground" Value="{StaticResource BrushAppleBlueLight}"/>
        <Setter Property="Margin"     Value="0,2,0,0"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         CARDS / PANELS
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="BaseCard" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource BrushCardBackground}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrushCardBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="10"/>
    </Style>

    <Style x:Key="ContentCard" TargetType="Border" BasedOn="{StaticResource BaseCard}">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin"  Value="0,0,0,8"/>
    </Style>

    <Style x:Key="AppIdentityCard" TargetType="Border" BasedOn="{StaticResource BaseCard}">
        <Setter Property="Padding" Value="14"/>
        <Setter Property="Margin"  Value="0,0,0,8"/>
    </Style>

    <Style x:Key="SectionCard" TargetType="Border" BasedOn="{StaticResource ContentCard}">
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="MetricCard" TargetType="Border" BasedOn="{StaticResource BaseCard}">
        <Setter Property="Padding" Value="12,14"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         BADGE / PILL — for status counts, mode tags
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="BadgePill" TargetType="Border">
        <Setter Property="Background"        Value="{StaticResource BrushSystemSecondaryBackground}"/>
        <Setter Property="CornerRadius"      Value="10"/>
        <Setter Property="Padding"           Value="8,3"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="BadgeText" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushNavyPrimary}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         INPUTS
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="FieldRow" TargetType="StackPanel">
        <Setter Property="Margin" Value="12,4,12,4"/>
    </Style>

    <Style x:Key="BorderlessTextInput" TargetType="TextBox">
        <Setter Property="FontSize"                 Value="13"/>
        <Setter Property="FontWeight"               Value="Normal"/>
        <Setter Property="Foreground"               Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="Background"               Value="Transparent"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="Padding"                  Value="0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush"               Value="{StaticResource BrushAppleBlue}"/>
    </Style>

    <!-- Boxed text input — bordered field for forms that need a visible outline -->
    <Style x:Key="BoxedTextInput" TargetType="TextBox">
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Foreground"      Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="Background"      Value="{StaticResource BrushSystemBackground}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrushSeparator}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8,6"/>
        <Setter Property="Height"          Value="32"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource BrushAppleBlue}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ComboBox base — minimal styling for consistent look (relies on default chrome) -->
    <Style x:Key="StandardComboBox" TargetType="ComboBox">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height"   Value="32"/>
        <Setter Property="Padding"  Value="8,4"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         TOGGLE SWITCH
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="AppleToggleButton" TargetType="ToggleButton">
        <Setter Property="Width"  Value="34"/>
        <Setter Property="Height" Value="19"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Track"
                            Background="{StaticResource BrushSystemTertiaryBackground}"
                            CornerRadius="9.5"
                            Width="34"
                            Height="19">
                        <Border x:Name="Knob"
                                Background="White"
                                CornerRadius="7.5"
                                Width="15"
                                Height="15"
                                Margin="2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="3" Opacity="0.15"/>
                            </Border.Effect>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{StaticResource BrushAppleBlue}"/>
                            <Setter TargetName="Knob"  Property="Margin"     Value="17,2,2,2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppleToggleRow" TargetType="StackPanel">
        <Setter Property="Orientation"       Value="Horizontal"/>
        <Setter Property="Margin"            Value="12,7"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         BUTTONS
    ═══════════════════════════════════════════════════════════ -->
    <!-- Primary action — navy, used for main "Apply / Run / Save" actions -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Height"     Value="38"/>
        <Setter Property="FontSize"   Value="13.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Background" Value="{StaticResource BrushNavyPrimary}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"     Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="9" Padding="18,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushNavyLight}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushNavyDark}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushTextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Accent action — bright blue, for secondary "highlight" actions (Export, Refresh) -->
    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{StaticResource BrushAppleBlue}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="9" Padding="18,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushAppleBlueLight}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushAppleBlueDark}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushTextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary — text-style button on transparent background -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Height"     Value="32"/>
        <Setter Property="FontSize"   Value="12.5"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushAppleBlue}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"     Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="9" Padding="10,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushSystemSecondaryBackground}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Outline — bordered button, neutral actions (Browse, Cancel) -->
    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="Height"     Value="32"/>
        <Setter Property="FontSize"   Value="12.5"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Background" Value="{StaticResource BrushSystemBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushSeparator}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor"     Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9" Padding="12,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushSystemSecondaryBackground}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger — destructive actions (Delete, Remove, Clear) -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{StaticResource BrushDanger}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="9" Padding="18,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushTextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         STATUS / CHIP
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="StatusRow" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Margin"      Value="12,10"/>
    </Style>

    <Style x:Key="StatusDot" TargetType="Ellipse">
        <Setter Property="Width"             Value="7"/>
        <Setter Property="Height"            Value="7"/>
        <Setter Property="Fill"              Value="{StaticResource BrushSuccess}"/>
        <Setter Property="Margin"            Value="0,0,6,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="StatusText" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
    </Style>

    <!-- Ghost button for dark surfaces — e.g. "Clear" on the log panel header -->
    <Style x:Key="DarkGhostButton" TargetType="Button">
        <Setter Property="Height"     Value="26"/>
        <Setter Property="FontSize"   Value="11.5"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushLogText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushLogTextDim}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor"     Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="10,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushLogTitleBar}"/>
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrushLogText}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         SEPARATOR
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="SeparatorLine" TargetType="Border">
        <Setter Property="Height"     Value="1"/>
        <Setter Property="Background" Value="{StaticResource BrushSeparatorThin}"/>
        <Setter Property="Margin"     Value="12,0"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         DATAGRID — shared look for all grid-based tools
         (WorksetManager, SectionsList, RoofTag, etc.)
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="StandardDataGrid" TargetType="DataGrid">
        <Setter Property="Background"                 Value="{StaticResource BrushSystemBackground}"/>
        <Setter Property="BorderThickness"            Value="0"/>
        <Setter Property="RowHeight"                  Value="30"/>
        <Setter Property="FontSize"                   Value="12.5"/>
        <Setter Property="Foreground"                 Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="GridLinesVisibility"        Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush"   Value="{StaticResource BrushSeparatorThin}"/>
        <Setter Property="VerticalGridLinesBrush"     Value="{StaticResource BrushSeparatorThin}"/>
        <Setter Property="HeadersVisibility"          Value="Column"/>
        <Setter Property="CanUserResizeRows"          Value="False"/>
        <Setter Property="AlternatingRowBackground"   Value="{StaticResource BrushSystemSecondaryBackground}"/>
        <Setter Property="RowBackground"              Value="{StaticResource BrushSystemBackground}"/>
        <Setter Property="SelectionMode"              Value="Extended"/>
    </Style>

    <Style x:Key="StandardDataGridColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background"      Value="{StaticResource BrushNavyPrimary}"/>
        <Setter Property="Foreground"      Value="{StaticResource BrushTextOnDark}"/>
        <Setter Property="FontSize"        Value="11.5"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Padding"         Value="10,8"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrushNavyLight}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <Style x:Key="StandardDataGridCell" TargetType="DataGridCell">
        <Setter Property="Padding"         Value="10,4"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource BrushTextPrimary}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushAppleBlueLight}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StandardDataGridRow" TargetType="DataGridRow">
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushSystemTertiaryBackground}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushAppleBlue}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         LIGHTWEIGHT DATAGRID BASES — for grids that drive their own
         "selected" highlight off a VM property (e.g. checkbox-driven
         row selection) instead of WPF's native DataGridRow.IsSelected.
         Unlike Standard*, these do NOT recolor on native selection,
         so they won't fight a custom IsSelected DataTrigger like
         SarRowStyle in SectionsListWindow.
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="DataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background"      Value="{StaticResource BrushSystemSecondaryBackground}"/>
        <Setter Property="Foreground"      Value="{StaticResource BrushTextSecondary}"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Padding"         Value="8,6"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrushCardBorder}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
        <Setter Property="Padding"         Value="8,4"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource BrushTextPrimary}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            </Trigger>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderThickness" Value="0"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DataGridRowStyle" TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="MinHeight"  Value="28"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushSystemTertiaryBackground}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         COMPACT INPUT / TOOLBAR BUTTON
    ═══════════════════════════════════════════════════════════ -->
    <!-- Compact bordered text input — for inline toolbar/filter fields
         (smaller footprint than BoxedTextInput, which targets full form rows) -->
    <Style x:Key="StyledTextInput" TargetType="TextBox">
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Foreground"      Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="Background"      Value="{StaticResource BrushSystemBackground}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrushCardBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="6,3"/>
        <Setter Property="Height"          Value="26"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush"      Value="{StaticResource BrushAppleBlue}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource BrushAppleBlue}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource BrushTextDisabled}"/>
                <Setter Property="Background" Value="{StaticResource BrushSystemSecondaryBackground}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Small secondary action — bordered, compact (toolbars, action-bar "Select all" etc.) -->
    <Style x:Key="SmallSecondaryButton" TargetType="Button">
        <Setter Property="Height"     Value="26"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Background" Value="{StaticResource BrushSystemSecondaryBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushCardBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"    Value="9,0"/>
        <Setter Property="Cursor"     Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushSystemTertiaryBackground}"/>
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrushAppleBlueLight}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushSeparator}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushSystemSecondaryBackground}"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushTextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
