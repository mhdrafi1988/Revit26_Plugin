<Window x:Class="Revit26_Plugin.AutoSlopeByPoint.V07.UI.Views.AutoSlopeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Auto Slope Engine - Revit 2026"
        Width="1080"
        Height="720"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource BrushSystemBackground}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Revit26_Plugin;component/Shared/SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="252"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ════════════════════════════════════════
             LEFT PANEL — CONTROLS
        ════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- App Identity Card -->
                <Border Style="{StaticResource AppIdentityCard}">
                    <StackPanel>
                        <TextBlock Text="Auto Slope" Style="{StaticResource AppName}"/>
                        <TextBlock Text="Revit 2026 · V4.0" Style="{StaticResource AppSubtitle}"/>
                    </StackPanel>
                </Border>

                <!-- Slope Section -->
                <Border Style="{StaticResource ContentCard}">
                    <StackPanel>
                        <TextBlock Text="Slope" Style="{StaticResource SectionTitle}"/>

                        <StackPanel Style="{StaticResource FieldRow}">
                            <TextBlock Text="Percentage" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding SlopeOptions}"
                                      SelectedItem="{Binding SlopePercent, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StringFormat={}{0}%}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <Border Style="{StaticResource SeparatorLine}"/>

                        <StackPanel Style="{StaticResource FieldRow}">
                            <TextBlock Text="Threshold distance" Style="{StaticResource FieldLabel}"/>
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="Meters" Style="{StaticResource UnitLabel}" DockPanel.Dock="Right"/>
                                <TextBox Style="{StaticResource BorderlessTextInput}"
                                         Text="{Binding ThresholdMeters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </DockPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Drain Detection Section -->
                <Border Style="{StaticResource ContentCard}">
                    <StackPanel>
                        <TextBlock Text="Drain Detection" Style="{StaticResource SectionTitle}"/>

                        <StackPanel Style="{StaticResource AppleToggleRow}">
                            <TextBlock Text="enable tolerance" Style="{StaticResource FieldValue}" VerticalAlignment="Center"/>
                            <ToggleButton Style="{StaticResource AppleToggleButton}"
                                          IsChecked="{Binding EnableDrainTolerance}"
                                          Margin="8,0,0,0"/>
                        </StackPanel>

                        <Border Style="{StaticResource SeparatorLine}"/>

                        <StackPanel Style="{StaticResource FieldRow}">
                            <TextBlock Text="tolerance radius" Style="{StaticResource FieldLabel}"/>
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="Milli Meters" Style="{StaticResource UnitLabel}" DockPanel.Dock="Right"/>
                                <TextBox Style="{StaticResource BorderlessTextInput}"
                                         Text="{Binding DrainToleranceMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding EnableDrainTolerance}"/>
                            </DockPanel>
                        </StackPanel>

                        <TextBlock Text="Finds plumbing fixtures and roof drains within the radius of selected points."
                                   Style="{StaticResource HintText}"
                                   Margin="12,0,12,10"
                                   Visibility="{Binding EnableDrainTolerance, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Border>

                <!-- Export Settings Section -->
                <Border Style="{StaticResource ContentCard}">
                    <StackPanel>
                        <TextBlock Text="Export" Style="{StaticResource SectionTitle}"/>

                        <StackPanel Style="{StaticResource AppleToggleRow}">
                            <TextBlock Text="Export to Excel" Style="{StaticResource FieldValue}" VerticalAlignment="Center"/>
                            <ToggleButton Style="{StaticResource AppleToggleButton}"
                                          IsChecked="{Binding ExportToExcel}"
                                          Margin="8,0,0,0"/>
                        </StackPanel>

                        <Border Style="{StaticResource SeparatorLine}"/>

                        <StackPanel Style="{StaticResource FieldRow}">
                            <TextBlock Text="Folder" Style="{StaticResource FieldLabel}"/>
                            <DockPanel LastChildFill="True">
                                <Button Content="Browse"
                                        DockPanel.Dock="Right"
                                        Margin="6,0,0,0"
                                        Command="{Binding BrowseFolderCommand}"/>
                                <TextBox Style="{StaticResource BorderlessTextInput}"
                                         Text="{Binding ExportFolderPath, Mode=TwoWay}"
                                         IsReadOnly="True"
                                         Foreground="{StaticResource BrushAppleBlue}"/>
                            </DockPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Run Button -->
                <Button Command="{Binding RunCommand}"
                        ToolTip="Calculate and apply slope to roof"
                        Margin="0,0,0,10">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Setter Property="Content" Value="Run AutoSlope"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasRun}" Value="True">
                                    <Setter Property="Content" Value="Processing..."/>
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Background" Value="{StaticResource BrushWarning}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasRun}" Value="False">
                                    <Setter Property="Content" Value="Run AutoSlope"/>
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Setter Property="Background" Value="{StaticResource BrushAppleBlue}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                    <Setter Property="Content" Value="✓ Complete"/>
                                    <Setter Property="Background" Value="{StaticResource BrushSuccess}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Export Summary Button -->
                <Button Content="Export Results"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ExportResultsCommand}"
                        Margin="0,0,0,10"/>

                <!-- Status Card -->
                <Border Style="{StaticResource ContentCard}">
                    <StackPanel Style="{StaticResource StatusRow}">
                        <Ellipse>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse" BasedOn="{StaticResource StatusDot}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRun}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource BrushWarning}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource BrushSuccess}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusText}"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Note: Ensure roof shape editing is enabled in Revit before running."
                           Style="{StaticResource HintText}"
                           Margin="12,0,12,10"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Separator between panels -->
        <GridSplitter Grid.Column="1"
                      Width="1"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource BrushSeparator}"/>

        <!-- ════════════════════════════════════════
             RIGHT PANEL — OUTPUT
        ════════════════════════════════════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- First Row Metrics: Longest Path | Tolerance Applied | Highest Elevation -->
            <UniformGrid Grid.Row="0" Columns="3" Rows="1" Margin="0,0,0,6">
                <Border Style="{StaticResource MetricCard}" Margin="0,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Longest Path" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding LongestPath_m, StringFormat=F2, FallbackValue=0.00}" Style="{StaticResource MetricNumberWarning}"/>
                        <TextBlock Text="Meters" Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="3,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Tolerance Applied" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding DrainToleranceMm, StringFormat=F0, FallbackValue=0}" Style="{StaticResource MetricNumberWarning}"/>
                        <TextBlock Text="Millimeters" Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCard}" Margin="3,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Highest elevation" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding HighestElevation_mm, StringFormat=F0, FallbackValue=0}" Style="{StaticResource MetricNumberDanger}"/>
                        <TextBlock Text="Millimeters" Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Second Row Metrics: Run duration | Vertices skipped | Drain count -->
            <UniformGrid Grid.Row="2" Columns="4" Rows="1" Margin="0,0,0,6">
                <Border Style="{StaticResource MetricCard}" Margin="0,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Run duration" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding RunDuration_sec, FallbackValue=0}" Style="{StaticResource MetricNumberSuccess}"/>
                        <TextBlock Text="Seconds" Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCard}" Margin="3,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Vertices skipped" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding VerticesSkipped, FallbackValue=0}" Style="{StaticResource MetricNumberAccent}"/>
                        <TextBlock Text="Boundary" Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCard}" Margin="3,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Picked Drain" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding PickedDrainCount, FallbackValue=0}" Style="{StaticResource MetricNumberAccent}"/>
                        <TextBlock Text="Detected" Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="3,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Final Drain Count" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding FinalDrainCount, FallbackValue=0}" Style="{StaticResource MetricNumberSuccess}"/>
                        <TextBlock Text="Detected" Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Third Row Metrics: Slope applied | Vertices processed -->
            <UniformGrid Grid.Row="4" Columns="2" Rows="1" Margin="0,0,0,6">
                <Border Style="{StaticResource MetricCard}" Margin="0,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Slope applied" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding SlopePercent, FallbackValue=0, StringFormat=F1}" Style="{StaticResource MetricNumberWarning}"/>
                        <TextBlock Text="Percent" Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCard}" Margin="3,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Vertices processed" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding VerticesProcessed, FallbackValue=0}" Style="{StaticResource MetricNumberAccent}"/>
                        <TextBlock Text="Vertices" Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Live Log Header -->
            <Border Grid.Row="8" Background="{StaticResource BrushLogBg}" CornerRadius="6,6,0,0" Padding="10,8">
                <DockPanel>
                    <TextBlock Text="Processing log" Style="{StaticResource FieldLabel}" Foreground="{StaticResource BrushLogTextDim}" VerticalAlignment="Center"/>
                    <Button Content="Clear"
                            DockPanel.Dock="Right"
                            Command="{Binding ClearLogCommand}" 
                            Width="70"
                            Height="28"/>
                </DockPanel>
            </Border>

            <!-- Live Log TextBox -->
            <TextBox Grid.Row="6"
                     Text="{Binding LogText, Mode=OneWay}"
                     VerticalScrollBarVisibility="Auto"
                     Background="{StaticResource BrushLogBg}"
                     Foreground="{StaticResource BrushLogText}"
                     FontFamily="Menlo, Monaco, Courier New, monospace"
                     FontSize="10"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     BorderThickness="0"
                     Margin="0,0,0,0"/>
        </Grid>
    </Grid>
</Window>