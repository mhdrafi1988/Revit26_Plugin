<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════════
         REVIT PLUGIN SHARED STYLE GUIDE  —  Apple-Inspired Theme (Optimized)
         Version : 2.1 (10% size reduction for 1200x800)
    ═══════════════════════════════════════════════════════════ -->

    <!-- ─── FONT FAMILY ───────────────────────────────────────── -->
    <FontFamily x:Key="SystemFont">-apple-system, BlinkMacSystemFont, Helvetica Neue, Segoe UI, sans-serif</FontFamily>

    <!-- ─── COLOR TOKENS (Apple-inspired palette) ─────────────── -->
    <Color x:Key="SystemBackground">#FFFFFF</Color>
    <Color x:Key="SystemSecondaryBackground">#F2F2F7</Color>
    <Color x:Key="SystemTertiaryBackground">#E5E5EA</Color>
    <Color x:Key="SeparatorColor">#E5E5EA</Color>
    <Color x:Key="SeparatorThin">#F2F2F7</Color>
    <Color x:Key="AppleBlue">#0071E3</Color>
    <Color x:Key="AppleBlueLight">#0077ED</Color>
    <Color x:Key="AppleBlueDark">#005BBF</Color>
    <Color x:Key="TextPrimary">#1C1C1E</Color>
    <Color x:Key="TextSecondary">#8E8E93</Color>
    <Color x:Key="TextTertiary">#AEAEB2</Color>
    <Color x:Key="TextDisabled">#C6C6C8</Color>
    <Color x:Key="ColorSuccess">#34C759</Color>
    <Color x:Key="ColorWarning">#FF9F0A</Color>
    <Color x:Key="ColorDanger">#FF453A</Color>
    <Color x:Key="ColorInfo">#64D2FF</Color>
    <Color x:Key="LogBackground">#1C1C1E</Color>
    <Color x:Key="LogTitleBar">#2C2C2E</Color>
    <Color x:Key="LogText">#EBEBF5</Color>
    <Color x:Key="LogTextDim">#636366</Color>
    <Color x:Key="LogSuccess">#34C759</Color>
    <Color x:Key="LogWarning">#FF9F0A</Color>
    <Color x:Key="LogError">#FF453A</Color>
    <Color x:Key="LogHighlight">#64D2FF</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="CardBorder">#E5E5EA</Color>
    <Color x:Key="IconTint">#8E8E93</Color>

    <!-- ─── SOLID COLOR BRUSHES ───────────────────────────────── -->
    <SolidColorBrush x:Key="BrushSystemBackground"        Color="{StaticResource SystemBackground}"/>
    <SolidColorBrush x:Key="BrushSystemSecondaryBackground" Color="{StaticResource SystemSecondaryBackground}"/>
    <SolidColorBrush x:Key="BrushSystemTertiaryBackground"  Color="{StaticResource SystemTertiaryBackground}"/>
    <SolidColorBrush x:Key="BrushSeparator"              Color="{StaticResource SeparatorColor}"/>
    <SolidColorBrush x:Key="BrushSeparatorThin"          Color="{StaticResource SeparatorThin}"/>
    <SolidColorBrush x:Key="BrushAppleBlue"              Color="{StaticResource AppleBlue}"/>
    <SolidColorBrush x:Key="BrushAppleBlueLight"         Color="{StaticResource AppleBlueLight}"/>
    <SolidColorBrush x:Key="BrushAppleBlueDark"          Color="{StaticResource AppleBlueDark}"/>
    <SolidColorBrush x:Key="BrushTextPrimary"            Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="BrushTextSecondary"          Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="BrushTextTertiary"           Color="{StaticResource TextTertiary}"/>
    <SolidColorBrush x:Key="BrushTextDisabled"           Color="{StaticResource TextDisabled}"/>
    <SolidColorBrush x:Key="BrushSuccess"                Color="{StaticResource ColorSuccess}"/>
    <SolidColorBrush x:Key="BrushWarning"                Color="{StaticResource ColorWarning}"/>
    <SolidColorBrush x:Key="BrushDanger"                 Color="{StaticResource ColorDanger}"/>
    <SolidColorBrush x:Key="BrushInfo"                   Color="{StaticResource ColorInfo}"/>
    <SolidColorBrush x:Key="BrushLogBg"                  Color="{StaticResource LogBackground}"/>
    <SolidColorBrush x:Key="BrushLogTitleBar"            Color="{StaticResource LogTitleBar}"/>
    <SolidColorBrush x:Key="BrushLogText"                Color="{StaticResource LogText}"/>
    <SolidColorBrush x:Key="BrushLogTextDim"             Color="{StaticResource LogTextDim}"/>
    <SolidColorBrush x:Key="BrushLogSuccess"             Color="{StaticResource LogSuccess}"/>
    <SolidColorBrush x:Key="BrushLogWarning"             Color="{StaticResource LogWarning}"/>
    <SolidColorBrush x:Key="BrushLogError"               Color="{StaticResource LogError}"/>
    <SolidColorBrush x:Key="BrushLogHighlight"           Color="{StaticResource LogHighlight}"/>
    <SolidColorBrush x:Key="BrushCardBackground"         Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="BrushCardBorder"             Color="{StaticResource CardBorder}"/>
    <SolidColorBrush x:Key="BrushIconTint"               Color="{StaticResource IconTint}"/>

    <!-- ─── CONVERTERS ────────────────────────────────────────── -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

    <!-- ═══════════════════════════════════════════════════════════
         TYPOGRAPHY — Reduced by ~10%
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="AppName" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <!-- 15 → 14 -->
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
    </Style>

    <Style x:Key="AppSubtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <!-- 11 → 10 -->
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <!-- 11 → 10 -->
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        <Setter Property="Margin" Value="12,10,12,5"/>
        <!-- 14,12,14,6 → 12,10,12,5 -->
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <!-- 11 → 10 -->
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <Style x:Key="FieldValue" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <!-- 13 → 12 -->
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
    </Style>

    <Style x:Key="HintText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="9"/>
        <!-- 10 → 9 -->
        <Setter Property="Foreground" Value="{StaticResource BrushTextTertiary}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,3,0,0"/>
    </Style>

    <Style x:Key="UnitLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <!-- 12 → 11 -->
        <Setter Property="Foreground" Value="{StaticResource BrushTextTertiary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="3,0,0,0"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         CARDS / PANELS — Reduced padding/margin
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="BaseCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushCardBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushCardBorder}"/>
        <Setter Property="BorderThickness" Value="0.5"/>
        <Setter Property="CornerRadius" Value="10,10,10,10"/>
        <!-- 12 → 10 -->
    </Style>

    <Style x:Key="ContentCard" TargetType="Border" BasedOn="{StaticResource BaseCard}">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <!-- 10 → 8 -->
    </Style>

    <Style x:Key="AppIdentityCard" TargetType="Border" BasedOn="{StaticResource BaseCard}">
        <Setter Property="Padding" Value="14"/>
        <!-- 16 → 14 -->
        <Setter Property="Margin" Value="0,0,0,8"/>
        <!-- 10 → 8 -->
    </Style>

    <Style x:Key="MetricCard" TargetType="Border" BasedOn="{StaticResource BaseCard}">
        <Setter Property="Padding" Value="12,14"/>
        <!-- 14,16 → 12,14 -->
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         METRIC STYLES — Reduced font sizes
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="MetricLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <!-- 11 → 10 -->
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        <Setter Property="Margin" Value="0,0,0,5"/>
        <!-- 6 → 5 -->
    </Style>

    <Style x:Key="MetricNumber" TargetType="TextBlock">
        <Setter Property="FontSize" Value="23"/>
        <!-- 26 → 23 -->
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
    </Style>

    <Style x:Key="MetricNumberAccent" TargetType="TextBlock" BasedOn="{StaticResource MetricNumber}">
        <Setter Property="Foreground" Value="{StaticResource BrushAppleBlue}"/>
    </Style>

    <Style x:Key="MetricNumberSuccess" TargetType="TextBlock" BasedOn="{StaticResource MetricNumber}">
        <Setter Property="Foreground" Value="{StaticResource BrushSuccess}"/>
    </Style>

    <Style x:Key="MetricUnit" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <!-- 11 → 10 -->
        <Setter Property="Foreground" Value="{StaticResource BrushTextTertiary}"/>
        <Setter Property="Margin" Value="0,3,0,0"/>
        <!-- 4 → 3 -->
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         INPUTS — Reduced margins
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="FieldRow" TargetType="StackPanel">
        <Setter Property="Margin" Value="12,4,12,4"/>
        <!-- 0 → 12,4 margins -->
    </Style>

    <Style x:Key="BorderlessTextInput" TargetType="TextBox">
        <Setter Property="FontSize" Value="12"/>
        <!-- 13 → 12 -->
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush" Value="{StaticResource BrushAppleBlue}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         TOGGLE SWITCH (Apple-style) — Slightly smaller
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="AppleToggleButton" TargetType="ToggleButton">
        <Setter Property="Width" Value="32"/>
        <!-- 36 → 32 -->
        <Setter Property="Height" Value="18"/>
        <!-- 20 → 18 -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Track"
                            Background="{StaticResource BrushSystemTertiaryBackground}"
                            CornerRadius="9"
                            Width="32"
                            Height="18">
                        <Border x:Name="Knob"
                                Background="White"
                                CornerRadius="7"
                                Width="14"
                                Height="14"
                                Margin="2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="3" Opacity="0.15"/>
                            </Border.Effect>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{StaticResource BrushSuccess}"/>
                            <Setter TargetName="Knob" Property="Margin" Value="16,2,2,2"/>
                            <!-- 18 → 16 -->
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppleToggleRow" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Margin" Value="12,7"/>
        <!-- 14,9 → 12,7 -->
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         BUTTONS — Reduced heights
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Height" Value="38"/>
        <!-- 42 → 38 -->
        <Setter Property="FontSize" Value="13"/>
        <!-- 14 → 13 -->
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Background" Value="{StaticResource BrushAppleBlue}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="9"    
                        Padding="18,0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Height" Value="32"/>
        <!-- 36 → 32 -->
        <Setter Property="FontSize" Value="12"/>
        <!-- 13 → 12 -->
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushAppleBlue}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="9"
                            Padding="10,0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         STATUS / CHIP
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="StatusRow" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Margin" Value="12,10"/>
        <!-- 14,12 → 12,10 -->
    </Style>

    <Style x:Key="StatusDot" TargetType="Ellipse">
        <Setter Property="Width" Value="6"/>
        <!-- 7 → 6 -->
        <Setter Property="Height" Value="6"/>
        <!-- 7 → 6 -->
        <Setter Property="Fill" Value="{StaticResource BrushSuccess}"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="StatusText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <!-- 12 → 11 -->
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         SEPARATOR
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="SeparatorLine" TargetType="Border">
        <Setter Property="Height" Value="0.5"/>
        <Setter Property="Background" Value="{StaticResource BrushSeparatorThin}"/>
        <Setter Property="Margin" Value="12,0"/>
        <!-- 14,0 → 12,0 -->
    </Style>
    

</ResourceDictionary>