<!--
    ╔══════════════════════════════════════════════════════════════════╗
    ║  File : Views/AutoSlopeWindow.xaml                              ║
    ║  View : AutoSlopeWindow  (MVVM Refactored)                      ║
    ║  Namespace: Revit26_Plugin.AutoSlopeByDrain_21                  ║
    ╚══════════════════════════════════════════════════════════════════╝
-->
<Window x:Class="Revit26_Plugin.AutoSlopeByDrain_21.Views.AutoSlopeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Auto Slope Engine — Revit 2026"
        Width="1180"
        Height="780"
        MinWidth="960"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="White">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Revit26_Plugin;component/Shared/SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Local converters re-used from SharedStyles -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════
         ROOT GRID  –  Left panel | Splitter | Right panel
    ═══════════════════════════════════════════════════════════════ -->
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             LEFT PANEL — CONTROLS
        ═══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ── App Identity ─────────────────────────────── -->
                <Border Style="{StaticResource AppIdentityCard}">
                    <StackPanel>
                        <TextBlock Text="Auto Slope"       Style="{StaticResource AppName}"/>
                        <TextBlock Text="Revit 2026 · V4.1" Style="{StaticResource AppSubtitle}"/>
                    </StackPanel>
                </Border>

                <!-- ── Roof Info ─────────────────────────────────── -->
                <Border Style="{StaticResource ContentCard}">
                    <StackPanel>
                        <TextBlock Text="Roof" Style="{StaticResource SectionTitle}"/>

                        <StackPanel Style="{StaticResource FieldRow}">
                            <TextBlock Text="Selected"     Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding RoofInfo, FallbackValue='—'}"
                                       Style="{StaticResource FieldValue}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Slope ─────────────────────────────────────── -->
                <Border Style="{StaticResource ContentCard}">
                    <StackPanel>
                        <TextBlock Text="Slope" Style="{StaticResource SectionTitle}"/>

                        <StackPanel Style="{StaticResource FieldRow}">
                            <TextBlock Text="Percentage" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding SlopeOptions}"
                                      Text="{Binding SlopeInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StringFormat={}{0}%}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <Border Style="{StaticResource SeparatorLine}"/>

                        <StackPanel Style="{StaticResource FieldRow}">
                            <TextBlock Text="Threshold distance" Style="{StaticResource FieldLabel}"/>
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="Meters" Style="{StaticResource UnitLabel}" DockPanel.Dock="Right"/>
                                <TextBox   Style="{StaticResource BorderlessTextInput}"
                                           Text="{Binding ThresholdMeters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </DockPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Drain Detection ───────────────────────────── -->
                <Border Style="{StaticResource ContentCard}">
                    <StackPanel>
                        <TextBlock Text="Drain Detection" Style="{StaticResource SectionTitle}"/>

                        <StackPanel Style="{StaticResource AppleToggleRow}">
                            <TextBlock Text="Enable tolerance"
                                       Style="{StaticResource FieldValue}"
                                       VerticalAlignment="Center"/>
                            <ToggleButton Style="{StaticResource AppleToggleButton}"
                                          IsChecked="{Binding EnableDrainTolerance}"
                                          Margin="8,0,0,0"/>
                        </StackPanel>

                        <Border Style="{StaticResource SeparatorLine}"/>

                        <StackPanel Style="{StaticResource FieldRow}">
                            <TextBlock Text="Tolerance radius" Style="{StaticResource FieldLabel}"/>
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="mm" Style="{StaticResource UnitLabel}" DockPanel.Dock="Right"/>
                                <TextBox   Style="{StaticResource BorderlessTextInput}"
                                           Text="{Binding DrainToleranceMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           IsEnabled="{Binding EnableDrainTolerance}"/>
                            </DockPanel>
                        </StackPanel>

                        <TextBlock Text="Finds plumbing fixtures and roof drains within the radius of selected points."
                                   Style="{StaticResource HintText}"
                                   Margin="12,0,12,10"
                                   Visibility="{Binding EnableDrainTolerance, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Border>

                <!-- ── Export ────────────────────────────────────── -->
                <Border Style="{StaticResource ContentCard}">
                    <StackPanel>
                        <TextBlock Text="Export" Style="{StaticResource SectionTitle}"/>

                        <StackPanel Style="{StaticResource AppleToggleRow}">
                            <TextBlock Text="Export to Excel"
                                       Style="{StaticResource FieldValue}"
                                       VerticalAlignment="Center"/>
                            <ToggleButton Style="{StaticResource AppleToggleButton}"
                                          IsChecked="{Binding ExportToExcel}"
                                          Margin="8,0,0,0"/>
                        </StackPanel>

                        <Border Style="{StaticResource SeparatorLine}"/>

                        <StackPanel Style="{StaticResource AppleToggleRow}">
                            <TextBlock Text="Detailed version"
                                       Style="{StaticResource FieldValue}"
                                       VerticalAlignment="Center"/>
                            <ToggleButton Style="{StaticResource AppleToggleButton}"
                                          IsChecked="{Binding IncludeVertexDetails}"
                                          IsEnabled="{Binding ExportToExcel}"
                                          Margin="8,0,0,0"/>
                        </StackPanel>

                        <Border Style="{StaticResource SeparatorLine}"/>

                        <StackPanel Style="{StaticResource FieldRow}">
                            <TextBlock Text="Folder" Style="{StaticResource FieldLabel}"/>
                            <DockPanel LastChildFill="True">
                                <Button Content="Browse"
                                        DockPanel.Dock="Right"
                                        Margin="6,0,0,0"
                                        Command="{Binding BrowseFolderCommand}"/>
                                <TextBox Style="{StaticResource BorderlessTextInput}"
                                         Text="{Binding ExportFolderPath, Mode=TwoWay}"
                                         IsReadOnly="True"
                                         Foreground="{StaticResource BrushAppleBlue}"/>
                            </DockPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Run Button ────────────────────────────────── -->
                <Button Command="{Binding RunCommand}"
                        ToolTip="Calculate and apply slope to roof"
                        Margin="0,0,0,10">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Setter Property="Content" Value="Run AutoSlope"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasRun}" Value="True">
                                    <Setter Property="Content"    Value="Processing…"/>
                                    <Setter Property="IsEnabled"  Value="False"/>
                                    <Setter Property="Background" Value="{StaticResource BrushWarning}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasRun}" Value="False">
                                    <Setter Property="Content"    Value="Run AutoSlope"/>
                                    <Setter Property="IsEnabled"  Value="True"/>
                                    <Setter Property="Background" Value="{StaticResource BrushAppleBlue}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                    <Setter Property="Content"    Value="✓ Complete"/>
                                    <Setter Property="Background" Value="{StaticResource BrushSuccess}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- ── Export Results Button ─────────────────────── -->
                <Button Content="Export Results"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ExportResultsCommand}"
                        Margin="0,0,0,10"/>

                <!-- ── Status Card ───────────────────────────────── -->
                <Border Style="{StaticResource ContentCard}">
                    <StackPanel Style="{StaticResource StatusRow}">
                        <Ellipse>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse" BasedOn="{StaticResource StatusDot}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRun}"     Value="True">
                                            <Setter Property="Fill" Value="{StaticResource BrushWarning}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource BrushSuccess}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusText}"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Note: Ensure roof shape editing is enabled in Revit before running."
                           Style="{StaticResource HintText}"
                           Margin="12,0,12,10"/>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Divider ────────────────────────────────────────────── -->
        <GridSplitter Grid.Column="1"
                      Width="1"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource BrushSeparator}"/>

        <!-- ═══════════════════════════════════════════════════════
             RIGHT PANEL — OUTPUT
             Rows:
               0  Metric row 1  (4 cards)
               1  gap
               2  Metric row 2  (4 cards)
               3  gap
               4  Metric row 3  (3 cards)
               5  gap
               6  Drain DataGrid section (*)
               7  gap
               8  Log header
               9  Live log TextBox
        ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 0  metric row 1 -->
                <RowDefinition Height="8"/>
                <!-- 1  gap -->
                <RowDefinition Height="Auto"/>
                <!-- 2  metric row 2 -->
                <RowDefinition Height="8"/>
                <!-- 3  gap -->
                <RowDefinition Height="Auto"/>
                <!-- 4  metric row 3 -->
                <RowDefinition Height="8"/>
                <!-- 5  gap -->
                <RowDefinition Height="*"/>
                <!-- 6  drain DataGrid (*) -->
                <RowDefinition Height="8"/>
                <!-- 7  gap -->
                <RowDefinition Height="Auto"/>
                <!-- 8  log header -->
                <RowDefinition Height="160"/>
                <!-- 9  live log -->
            </Grid.RowDefinitions>

            <!-- ── Metric row 1 : Longest Path | Tolerance | Highest Elev | Avg Slope ── -->
            <UniformGrid Grid.Row="0" Columns="4" Rows="1">
                <Border Style="{StaticResource MetricCard}" Margin="0,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Longest Path"     Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding LongestPath_m, StringFormat=F2, FallbackValue=0.00}"
                                   Style="{StaticResource MetricNumber}" Foreground="Orange"/>
                        <TextBlock Text="Meters"           Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="3,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Tolerance Applied" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding DrainToleranceMm, StringFormat=F0, FallbackValue=0}"
                                   Style="{StaticResource MetricNumber}" Foreground="Orange"/>
                        <TextBlock Text="Millimeters"       Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="3,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Highest Elevation" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding HighestElevation_mm, StringFormat=F0, FallbackValue=0}"
                                   Style="{StaticResource MetricNumber}" Foreground="Red"/>
                        <TextBlock Text="Millimeters"       Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="3,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Avg Slope Applied" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding AvgSlopePercent, FallbackValue=0, StringFormat=F1}"
                                   Style="{StaticResource MetricNumberAccent}"/>
                        <TextBlock Text="Percent"           Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── Metric row 2 : Run Duration | Vertices Skipped | Picked Drain | Final Drain ── -->
            <UniformGrid Grid.Row="2" Columns="4" Rows="1">
                <Border Style="{StaticResource MetricCard}" Margin="0,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Run Duration"    Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding RunDuration_sec, FallbackValue=0}"
                                   Style="{StaticResource MetricNumberSuccess}"/>
                        <TextBlock Text="Seconds"         Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="3,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Vertices Skipped" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding VerticesSkipped, FallbackValue=0}"
                                   Style="{StaticResource MetricNumber}" Foreground="BlueViolet"/>
                        <TextBlock Text="Boundary"         Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="3,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Picked Drain"   Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding PickedDrainCount, FallbackValue=0}"
                                   Style="{StaticResource MetricNumber}" Foreground="Cyan"/>
                        <TextBlock Text="Detected"       Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="3,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Final Drain Count" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding FinalDrainCount, FallbackValue=0}"
                                   Style="{StaticResource MetricNumber}" Foreground="YellowGreen"/>
                        <TextBlock Text="Detected"          Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── Metric row 3 : Pct1 | Pct2 | Vertices Processed ── -->
            <UniformGrid Grid.Row="4" Columns="3" Rows="1">
                <Border Style="{StaticResource MetricCard}" Margin="0,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Percentage 1 Applied" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding SlopePercent, FallbackValue=0, StringFormat=F1}"
                                   Style="{StaticResource MetricNumber}" Foreground="DarkOrange"/>
                        <TextBlock Text="Percent"              Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="3,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Percentage 2 Applied" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding Percentage2Applied, FallbackValue=0, StringFormat=F1}"
                                   Style="{StaticResource MetricNumberSuccess}"/>
                        <TextBlock Text="Percent"              Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="3,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Vertices Processed" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="{Binding VerticesProcessed, FallbackValue=0}"
                                   Style="{StaticResource MetricNumberAccent}"/>
                        <TextBlock Text="Vertices"           Style="{StaticResource MetricUnit}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ══════════════════════════════════════════════════
                 DRAIN DATA-GRID SECTION  (Row 6 — fills *)
            ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="6"
                    Background="{StaticResource BrushLogBg}"
                    CornerRadius="6"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- toolbar -->
                        <RowDefinition Height="*"/>
                        <!-- DataGrid -->
                    </Grid.RowDefinitions>

                    <!-- Drain toolbar -->
                    <Border Grid.Row="0"
                            CornerRadius="6,6,0,0"
                            Padding="10,7">
                        <DockPanel>
                            <!-- Section label -->
                            <TextBlock Text="Drain Management"
                                       Style="{StaticResource FieldLabel}"
                                       Foreground="{StaticResource BrushLogTextDim}"
                                       VerticalAlignment="Center"/>

                            <!-- Right-side controls -->
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">

                                <!-- Filter by size -->
                                <TextBlock Text="Filter:"
                                           Style="{StaticResource FieldLabel}"
                                           Foreground="{StaticResource BrushLogTextDim}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                                <ComboBox ItemsSource="{Binding SizeFilters}"
                                          SelectedItem="{Binding SelectedSizeFilter, Mode=TwoWay}"
                                          MinWidth="130"
                                          Margin="0,0,10,0"/>

                                <!-- Selection helpers -->
                                <Button Content="All"
                                        Command="{Binding SelectAllCommand}"
                                        Width="44" Height="26"
                                        Margin="0,0,4,0"/>
                                <Button Content="None"
                                        Command="{Binding SelectNoneCommand}"
                                        Width="44" Height="26"
                                        Margin="0,0,4,0"/>
                                <Button Content="Invert"
                                        Command="{Binding InvertSelectionCommand}"
                                        Width="52" Height="26"
                                        Margin="0,0,10,0"/>

                                <!-- Selected count badge -->
                                <Border Background="{StaticResource BrushAppleBlue}"
                                        CornerRadius="10"
                                        Padding="8,2"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding SelectedDrainsCount, FallbackValue=0}"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"
                                                   FontSize="11"/>
                                        <TextBlock Text=" selected"
                                                   Foreground="White"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Drain DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding FilteredDrainsView}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#06000000"
                              BorderThickness="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              FontSize="11">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Padding"          Value="8,5"/>
                                <Setter Property="FontSize"         Value="10"/>
                                <Setter Property="FontWeight"       Value="SemiBold"/>
                                <Setter Property="Foreground"       Value="{StaticResource BrushLogTextDim}"/>
                                <Setter Property="Background"       Value="Transparent"/>
                                <Setter Property="BorderThickness"  Value="0,0,0,1"/>
                                <Setter Property="BorderBrush"      Value="{StaticResource BrushSeparator}"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding"         Value="8,4"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>

                            <!-- Checkbox -->
                            <DataGridTemplateColumn Header="✓" Width="40" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay,
                                                              UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Drain ID -->
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding DrainId}"
                                                Width="40"
                                                IsReadOnly="True"/>

                            <!-- Shape type -->
                            <DataGridTextColumn Header="Shape"
                                                Binding="{Binding ShapeType}"
                                                Width="90"
                                                IsReadOnly="True"/>

                            <!-- Size category -->
                            <DataGridTextColumn Header="Size (mm)"
                                                Binding="{Binding SizeCategory}"
                                                Width="110"
                                                IsReadOnly="True"/>

                            <!-- Width -->
                            <DataGridTextColumn Header="W (mm)"
                                                Binding="{Binding Width, StringFormat={}{0:F0}}"
                                                Width="70"
                                                IsReadOnly="True"/>

                            <!-- Height -->
                            <DataGridTextColumn Header="H (mm)"
                                                Binding="{Binding Height, StringFormat={}{0:F0}}"
                                                Width="70"
                                                IsReadOnly="True"/>

                            <!-- Center X -->
                            <DataGridTextColumn Header="X (mm)"
                                                Binding="{Binding CenterPoint.X, StringFormat={}{0:F0}}"
                                                Width="80"
                                                IsReadOnly="True"/>

                            <!-- Center Y -->
                            <DataGridTextColumn Header="Y (mm)"
                                                Binding="{Binding CenterPoint.Y, StringFormat={}{0:F0}}"
                                                Width="80"
                                                IsReadOnly="True"/>

                            <!-- Center Z -->
                            <DataGridTextColumn Header="Z (mm)"
                                                Binding="{Binding CenterPoint.Z, StringFormat={}{0:F0}}"
                                                Width="80"
                                                IsReadOnly="True"/>

                            <!-- Vertex count -->
                            <DataGridTextColumn Header="Vertices"
                                                Binding="{Binding DrainVertices.Count, FallbackValue=0}"
                                                Width="68"
                                                IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ── Live Log header (Row 8) ─────────────────────── -->
            <Border Grid.Row="8"
                    Background="{StaticResource BrushLogBg}"
                    CornerRadius="6,6,0,0"
                    Padding="10,8">
                <DockPanel>
                    <TextBlock Text="Processing log"
                               Style="{StaticResource FieldLabel}"
                               Foreground="{StaticResource BrushLogTextDim}"
                               VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Copy"
                                Command="{Binding CopyLogCommand}"
                                Width="60" Height="26"
                                Margin="0,0,6,0"/>
                        <Button Content="Clear"
                                Command="{Binding ClearLogCommand}"
                                Width="60" Height="26"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Live Log TextBox (Row 9) ───────────────────── -->
            <TextBox Grid.Row="9"
                     x:Name="LogTextBox"
                     Text="{Binding LogText, Mode=OneWay}"
                     VerticalScrollBarVisibility="Auto"
                     Background="{StaticResource BrushLogBg}"
                     Foreground="{StaticResource BrushLogText}"
                     FontFamily="Menlo, Monaco, Courier New, monospace"
                     FontSize="10"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     BorderThickness="0"/>
        </Grid>
    </Grid>
</Window>