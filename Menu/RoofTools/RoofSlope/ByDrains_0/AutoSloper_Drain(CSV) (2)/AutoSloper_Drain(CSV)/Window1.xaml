<Window x:Class="Revit26_Plugin.Asd_19.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Revit26_Plugin.Asd_19.Views"
        mc:Ignorable="d"
        Title="Auto Roof Sloper"
        Height="860"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Revit26_Plugin;component/Shared/SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Root background -->
    <Border Background="{StaticResource BrushSystemSecondaryBackground}">
        <Grid Margin="14,12,14,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- Two columns -->
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════
                 HEADER BAR
            ═══════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Style="{StaticResource AppIdentityCard}"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                        <TextBlock Text="Auto Roof Sloper" Style="{StaticResource AppName}"/>
                        <TextBlock Text="Automated drainage slope calculation for Revit roofs" Style="{StaticResource AppSubtitle}"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="✕ Close"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════
                 TWO-COLUMN LAYOUT
            ═══════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="520"/>
                    <ColumnDefinition Width="14"/>
                    <!-- gutter -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─────────────────────────────────────
                     LEFT COLUMN
                ───────────────────────────────────────── -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Card 1: Roof Info -->
                        <RowDefinition Height="*"/>
                        <!-- Card 2: Slope & Drains -->
                        <RowDefinition Height="Auto"/>
                        <!-- Card 3: Export -->
                        <RowDefinition Height="Auto"/>
                        <!-- Action Buttons -->
                    </Grid.RowDefinitions>

                    <!-- ── CARD 1 : Roof Info ── -->
                    <Border Grid.Row="0" Style="{StaticResource ContentCard}">
                        <StackPanel>
                            <TextBlock Text="SELECTED ROOF"
                                       Style="{StaticResource SectionTitle}"/>
                            <Border Style="{StaticResource SeparatorLine}"/>
                            <StackPanel Style="{StaticResource FieldRow}" Orientation="Horizontal" Margin="12,8,12,10">
                                <StackPanel VerticalAlignment="Center" Width="340">
                                    <TextBlock Text="Roof" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="{Binding RoofInfo}"
                                               Style="{StaticResource FieldValue}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Button Content="Change Roof"
                                        Command="{Binding ChangeRoofCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        VerticalAlignment="Center"
                                        Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── CARD 2 : Slope Config & Drain Management ── -->
                    <Border Grid.Row="1" Style="{StaticResource ContentCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="SLOPE CONFIGURATION &amp; DRAIN MANAGEMENT"
                                       Style="{StaticResource SectionTitle}"/>
                            <Border Grid.Row="1" Style="{StaticResource SeparatorLine}"/>

                            <!-- Slope input row -->
                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        Margin="12,8,12,6">
                                <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Slope Percentage" Style="{StaticResource FieldLabel}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <ComboBox ItemsSource="{Binding SlopeOptions}"
                                                  Text="{Binding SlopeInput}"
                                                  Width="70"
                                                  IsEditable="True"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="%" Style="{StaticResource UnitLabel}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Connection Threshold input -->
                                <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Connection Threshold" Style="{StaticResource FieldLabel}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox Text="{Binding ConnectionThresholdInput, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="60"
                                                 VerticalAlignment="Center"
                                                 ToolTip="Max distance between connected vertices. Increase for large roofs, decrease for denser grids."/>
                                        <TextBlock Text=" m" Style="{StaticResource UnitLabel}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Path sample count input -->
                                <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Path Samples" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding PathSampleCountInput, UpdateSourceTrigger=PropertyChanged}"
                                             Width="50"
                                             VerticalAlignment="Center"
                                             ToolTip="Points tested along each edge to confirm it lies on the roof face. Higher = stricter but slower. Min 2, recommended 5-20."/>
                                </StackPanel>

                                <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Filter by Size" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox ItemsSource="{Binding SizeFilters}"
                                              SelectedItem="{Binding SelectedSizeFilter}"
                                              Width="140"
                                              VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel VerticalAlignment="Bottom">
                                    <Button Content="Apply Slope"
                                            Command="{Binding ApplySlopesCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Height="32"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Selection controls row -->
                            <StackPanel Grid.Row="3" Margin="12,0,12,6">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button Content="Select All"
                                            Command="{Binding SelectAllCommand}"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="0,0,4,0"/>
                                    <Button Content="Select None"
                                            Command="{Binding SelectNoneCommand}"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="0,0,4,0"/>
                                    <Button Content="Invert"
                                            Command="{Binding InvertSelectionCommand}"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="0,0,12,0"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Selected: " Style="{StaticResource FieldLabel}" Margin="0"/>
                                        <TextBlock Text="{Binding SelectedDrainsCount}"
                                                   Style="{StaticResource FieldValue}"
                                                   Foreground="{StaticResource BrushAppleBlue}"/>
                                    </StackPanel>
                                </StackPanel>

                                <DataGrid ItemsSource="{Binding FilteredDrainsView}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          Height="200"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          BorderThickness="0.5"
                                          BorderBrush="{StaticResource BrushCardBorder}"
                                          Background="{StaticResource BrushCardBackground}"
                                          RowBackground="{StaticResource BrushCardBackground}"
                                          AlternatingRowBackground="{StaticResource BrushSystemSecondaryBackground}"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="{StaticResource BrushSeparatorThin}"
                                          HeadersVisibility="Column"
                                          FontSize="11"
                                          Margin="0,0,0,8">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="✓" Width="40">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Shape"    Binding="{Binding ShapeType}"                        Width="80"/>
                                        <DataGridTextColumn Header="Size (mm)" Binding="{Binding SizeCategory}"                   Width="110"/>
                                        <DataGridTextColumn Header="W (mm)"   Binding="{Binding Width,  StringFormat={}{0:F0}}"   Width="60"/>
                                        <DataGridTextColumn Header="H (mm)"   Binding="{Binding Height, StringFormat={}{0:F0}}"   Width="60"/>
                                        <DataGridTextColumn Header="X"        Binding="{Binding CenterPoint.X, StringFormat={}{0:F0}}" Width="60"/>
                                        <DataGridTextColumn Header="Y"        Binding="{Binding CenterPoint.Y, StringFormat={}{0:F0}}" Width="60"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── CARD 3 : Export Settings ── -->
                    <Border Grid.Row="2" Style="{StaticResource ContentCard}">
                        <StackPanel>
                            <TextBlock Text="EXPORT SETTINGS" Style="{StaticResource SectionTitle}"/>
                            <Border Style="{StaticResource SeparatorLine}"/>

                            <!-- Folder path row -->
                            <Grid Margin="12,8,12,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Export Folder" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding ExportFolderPath}"
                                             IsReadOnly="True"
                                             Style="{StaticResource BorderlessTextInput}"
                                             Background="{StaticResource BrushSystemSecondaryBackground}"
                                             Padding="6,4"
                                             BorderThickness="0.5"
                                             BorderBrush="{StaticResource BrushCardBorder}"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Browse…"
                                        Command="{Binding BrowseExportFolderCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        VerticalAlignment="Bottom"
                                        Margin="8,0,0,0"/>
                            </Grid>

                            <!-- Toggles row -->
                            <StackPanel Orientation="Horizontal" Margin="12,4,12,10">
                                <StackPanel Style="{StaticResource AppleToggleRow}" Margin="0,0,16,0">
                                    <ToggleButton IsChecked="{Binding ExportToCsv}"
                                                  Style="{StaticResource AppleToggleButton}"
                                                  Margin="0,0,6,0"/>
                                    <TextBlock Text="Enable CSV Export" Style="{StaticResource FieldLabel}" Margin="0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource AppleToggleRow}" Margin="0,0,16,0">
                                    <ToggleButton IsChecked="{Binding IncludeVertexDetails}"
                                                  IsEnabled="{Binding ExportToCsv}"
                                                  Style="{StaticResource AppleToggleButton}"
                                                  Margin="0,0,6,0"/>
                                    <TextBlock Text="Include Vertex Details" Style="{StaticResource FieldLabel}" Margin="0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Content="Export Now"
                                        Command="{Binding ExportResultsCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        IsEnabled="{Binding ExportToCsv}"
                                        VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="Exports include drain locations, vertex paths and elevation data."
                                       Style="{StaticResource HintText}"
                                       Margin="12,0,12,8"/>
                        </StackPanel>
                    </Border>

                    <!-- ── ACTION BUTTONS ── -->
                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,6,0,0">
                        <Button Content="OK"
                                Command="{Binding OkCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Width="100"
                                Margin="0,0,8,0"/>
                        <Button Content="Cancel"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Width="100"/>
                    </StackPanel>
                </Grid>

                <!-- ─────────────────────────────────────
                     RIGHT COLUMN
                ───────────────────────────────────────── -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Card 4: 3x2 Metric grid -->
                        <RowDefinition Height="*"/>
                        <!-- Card 5: Log -->
                    </Grid.RowDefinitions>

                    <!-- ── CARD 4 : Results — 3×2 Metric Grid ── -->
                    <Border Grid.Row="0" Style="{StaticResource ContentCard}">
                        <StackPanel>
                            <TextBlock Text="RESULTS" Style="{StaticResource SectionTitle}"/>
                            <Border Style="{StaticResource SeparatorLine}"/>

                            <UniformGrid Rows="2" Columns="3" Margin="10,8,10,10">

                                <!-- Row 1, Col 1 : Longest Path -->
                                <Border Style="{StaticResource MetricCard}" Margin="0,0,6,6">
                                    <StackPanel>
                                        <TextBlock Text="LONGEST PATH" Style="{StaticResource MetricLabel}"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding LongestPathDisplay}"
                                                       Style="{StaticResource MetricNumberAccent}"/>
                                            <TextBlock Text=" m" Style="{StaticResource MetricUnit}" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Row 1, Col 2 : Max Offset -->
                                <Border Style="{StaticResource MetricCard}" Margin="3,0,3,6">
                                    <StackPanel>
                                        <TextBlock Text="MAX OFFSET" Style="{StaticResource MetricLabel}"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding MaxOffsetDisplay}"
                                                       Style="{StaticResource MetricNumber}"/>
                                            <TextBlock Text=" mm" Style="{StaticResource MetricUnit}" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Row 1, Col 3 : Drain Count -->
                                <Border Style="{StaticResource MetricCard}" Margin="6,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="DRAINS SELECTED" Style="{StaticResource MetricLabel}"/>
                                        <TextBlock Text="{Binding SelectedDrainsCount}"
                                                   Style="{StaticResource MetricNumberSuccess}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Row 2, Col 1 : Slope % -->
                                <Border Style="{StaticResource MetricCard}" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="SLOPE" Style="{StaticResource MetricLabel}"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding SlopeInput}"
                                                       Style="{StaticResource MetricNumber}"/>
                                            <TextBlock Text=" %" Style="{StaticResource MetricUnit}" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Row 2, Col 2 : Slope Applied status -->
                                <Border Style="{StaticResource MetricCard}" Margin="3,0,3,0">
                                    <StackPanel>
                                        <TextBlock Text="STATUS" Style="{StaticResource MetricLabel}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
                                            <Ellipse Style="{StaticResource StatusDot}"/>
                                            <TextBlock Style="{StaticResource StatusText}">
                                                <TextBlock.Text>
                                                    <Binding Path="SlopeApplied" StringFormat="{}{0}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Text="Slope Applied" Style="{StaticResource HintText}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Row 2, Col 3 : Roof ID -->
                                <Border Style="{StaticResource MetricCard}" Margin="6,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="ROOF INFO" Style="{StaticResource MetricLabel}"/>
                                        <TextBlock Text="{Binding RoofInfo}"
                                                   Style="{StaticResource FieldValue}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   MaxWidth="150"/>
                                    </StackPanel>
                                </Border>

                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- ── CARD 5 : Operation Log ── -->
                    <Border Grid.Row="1" Style="{StaticResource ContentCard}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Log header -->
                            <Grid Grid.Row="0" Margin="12,10,12,6">
                                <TextBlock Text="OPERATION LOG"
                                           Style="{StaticResource SectionTitle}"
                                           Margin="0" VerticalAlignment="Center"/>
                                <Button Content="Copy Log"
                                        Command="{Binding CopyLogCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        HorizontalAlignment="Right"
                                        Height="24"/>
                            </Grid>

                            <Border Grid.Row="1" Style="{StaticResource SeparatorLine}"/>

                            <!-- Log body — dark terminal style -->
                            <Border Grid.Row="2"
                                    Background="{StaticResource BrushLogBg}"
                                    CornerRadius="0,0,10,10"
                                    Margin="0"
                                    MinHeight="250"
                                    MaxHeight="250">
                                <TextBox Text="{Binding LogText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         FontSize="10"
                                         Foreground="{StaticResource BrushLogText}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="12,8"
                                         TextWrapping="Wrap"/>
                            </Border>
                        </Grid>
                    </Border>

                </Grid>
                <!-- end right column -->

            </Grid>
            <!-- end two-column grid -->

        </Grid>
    </Border>
</Window>
