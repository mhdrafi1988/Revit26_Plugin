<Window x:Class="Revit26_Plugin.OuterCurveDivider.V001.Views.CurveDividerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Revit26_Plugin.Shared.Models"
        Title="Curve Point Divider"
        Width="860" Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BrushSystemSecondaryBackground}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Revit26_Plugin;component/Shared/SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Shared converter: LogLevel → coloured brush -->
            <conv:LogLevelToColorConverter x:Key="LogLevelToColor"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0 header bar -->
            <RowDefinition Height="10"/>     <!-- 1 -->
            <RowDefinition Height="Auto"/>   <!-- 2 type section title -->
            <RowDefinition Height="Auto"/>   <!-- 3 type grid -->
            <RowDefinition Height="8"/>      <!-- 4 -->
            <RowDefinition Height="Auto"/>   <!-- 5 edges toolbar -->
            <RowDefinition Height="*" MinHeight="150"/> <!-- 6 edges grid -->
            <RowDefinition Height="8"/>      <!-- 7 -->
            <RowDefinition Height="Auto"/>   <!-- 8 log title -->
            <RowDefinition Height="130"/>    <!-- 9 log panel -->
            <RowDefinition Height="12"/>     <!-- 10 -->
            <RowDefinition Height="Auto"/>   <!-- 11 close -->
        </Grid.RowDefinitions>

        <!-- ── Header bar ── -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
            <StackPanel>
                <TextBlock Text="Curve Point Divider" Style="{StaticResource HeaderTitle}"/>
                <TextBlock Style="{StaticResource HeaderSubtitle}" TextWrapping="Wrap"
                           Text="Each edge's point count is seeded from its length (4 / 8 / 12 / L÷2) and is editable per row. Type rules and per-edge overrides still apply. Straight (Line) edges are filtered out; interior points only."/>
            </StackPanel>
        </Border>

        <!-- ── Per-type defaults ── -->
        <TextBlock Grid.Row="2" Text="DEFAULT RULE BY EDGE TYPE" Style="{StaticResource SectionTitle}"/>
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding TypeSettings}"
                  Style="{StaticResource StandardDataGrid}"
                  ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                  CellStyle="{StaticResource DataGridCellStyle}"
                  RowStyle="{StaticResource DataGridRowStyle}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  RowHeight="36" MaxHeight="160">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Edge Type" Binding="{Binding TypeName}" Width="150" IsReadOnly="True"/>

                <DataGridTemplateColumn Header="Mode" Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <RadioButton Content="Distance" Margin="0,0,12,0" VerticalContentAlignment="Center"
                                             IsChecked="{Binding ModeByDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <RadioButton Content="Count" VerticalContentAlignment="Center"
                                             IsChecked="{Binding ModeByCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Target (m)" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox Style="{StaticResource BoxedTextInput}" Height="26" Padding="6,2" Width="62"
                                         IsEnabled="{Binding ModeByDistance}"
                                         Text="{Binding TargetMeters, StringFormat=F2, UpdateSourceTrigger=LostFocus}"/>
                                <TextBlock Text="m" Style="{StaticResource UnitLabel}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Count (pts)" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Style="{StaticResource BoxedTextInput}" Height="26" Padding="6,2" Width="62"
                                     HorizontalAlignment="Left"
                                     IsEnabled="{Binding ModeByCount}"
                                     Text="{Binding FixedCount, UpdateSourceTrigger=LostFocus}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Edges toolbar ── -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="EDGES" Style="{StaticResource SectionTitle}" Margin="0,0,10,0"/>
                <Button Content="Select All"  Style="{StaticResource SmallSecondaryButton}" Width="86" Command="{Binding SelectAllCommand}"/>
                <Button Content="Select None" Style="{StaticResource SmallSecondaryButton}" Width="86" Margin="6,0,0,0" Command="{Binding SelectNoneCommand}"/>
            </StackPanel>
            <Button Grid.Column="2" Content="Apply Points" Style="{StaticResource PrimaryButton}"
                    Width="150" Command="{Binding ApplyCommand}"/>
        </Grid>

        <!-- ── Edges grid (override + editable point count) ── -->
        <DataGrid Grid.Row="6" Margin="0,6,0,0"
                  ItemsSource="{Binding Edges}"
                  Style="{StaticResource StandardDataGrid}"
                  ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                  CellStyle="{StaticResource DataGridCellStyle}"
                  RowStyle="{StaticResource DataGridRowStyle}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  RowHeight="36">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="✓" Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="#"        Binding="{Binding Index}"                    Width="40"  IsReadOnly="True"/>
                <DataGridTextColumn Header="Type"     Binding="{Binding CurveTypeName}"            Width="115" IsReadOnly="True"/>
                <DataGridTextColumn Header="Len (m)"  Binding="{Binding LengthM, StringFormat=F3}" Width="85"  IsReadOnly="True"/>

                <DataGridTemplateColumn Header="Override" Width="78">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding HasOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Mode" Width="112">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox Style="{StaticResource StandardComboBox}" Height="26"
                                      IsEnabled="{Binding HasOverride}"
                                      ItemsSource="{Binding DataContext.ModeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding OverrideModeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Target (m)" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox Style="{StaticResource BoxedTextInput}" Height="26" Padding="6,2" Width="56"
                                         IsEnabled="{Binding OverrideDistanceEnabled}"
                                         Text="{Binding OverrideTargetMeters, StringFormat=F2, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                                <TextBlock Text="m" Style="{StaticResource UnitLabel}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Editable point count (length-seeded). Editable when count-driven;
                     shows the computed result (greyed) when distance-driven. -->
                <DataGridTemplateColumn Header="Points" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Style="{StaticResource BoxedTextInput}" Height="26" Padding="6,2" Width="64"
                                     HorizontalAlignment="Left"
                                     IsEnabled="{Binding IsCountDriven}"
                                     Text="{Binding FinalPointCount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Log ── -->
        <TextBlock Grid.Row="8" Text="ACTIVITY LOG" Style="{StaticResource SectionTitle}"/>
        <Border Grid.Row="9" Background="{StaticResource BrushLogBg}" CornerRadius="8">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto" Padding="10,8">
                <ItemsControl ItemsSource="{Binding LogEntries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <TextBlock Text="{Binding Time, StringFormat=HH:mm:ss}"
                                           Foreground="{StaticResource BrushLogTextDim}"
                                           FontFamily="Consolas" FontSize="11.5" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding Message}"
                                           Foreground="{Binding Level, Converter={StaticResource LogLevelToColor}}"
                                           FontFamily="Consolas" FontSize="11.5" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ── Close ── -->
        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close" Style="{StaticResource OutlineButton}" Width="90" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
