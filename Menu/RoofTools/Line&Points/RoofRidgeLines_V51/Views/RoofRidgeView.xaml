<Window
    x:Class="Revit26_Plugin.RoofTools.LineAndPoints.RoofRidgeLines_V51.Views.RoofRidgeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="clr-namespace:Revit26_Plugin.RoofTools.LineAndPoints.RoofRidgeLines_V51.Converters"
    mc:Ignorable="d"
    Title="Roof Ridge — Voronoi Generation  [V51]"
    Width="820" Height="680" MinWidth="640" MinHeight="520"
    WindowStartupLocation="CenterScreen"
    Background="#1E1E2E" Foreground="#CDD6F4">

    <Window.Resources>
        <conv:InverseBoolConverter      x:Key="InverseBool"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="RevitButton" TargetType="Button">
            <Setter Property="Background"      Value="#313244"/>
            <Setter Property="Foreground"      Value="#CDD6F4"/>
            <Setter Property="BorderBrush"     Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource RevitButton}">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#89B4FA"/>
            <Setter Property="Margin"     Value="0,8,0,4"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#313244"/>
            <Setter Property="Foreground"      Value="#CDD6F4"/>
            <Setter Property="BorderBrush"     Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="CaretBrush"      Value="#CDD6F4"/>
            <Setter Property="SelectionBrush"  Value="#89B4FA"/>
        </Style>

        <Style x:Key="RidgeGrid" TargetType="DataGrid">
            <Setter Property="Background"               Value="#181825"/>
            <Setter Property="Foreground"               Value="#CDD6F4"/>
            <Setter Property="BorderBrush"              Value="#45475A"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#313244"/>
            <Setter Property="RowBackground"            Value="#181825"/>
            <Setter Property="AlternatingRowBackground" Value="#1E1E2E"/>
            <Setter Property="FontSize"                 Value="11"/>
        </Style>

        <Style x:Key="RidgeGridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background"  Value="#313244"/>
            <Setter Property="Foreground"  Value="#89B4FA"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Padding"     Value="6,4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Voronoi Ridge Generation"
                       FontSize="18" FontWeight="Bold" Foreground="#89B4FA"/>
            <TextBlock Text="Roof → Drain Groups → Voronoi Edges → Shape Points + Red Detail Lines"
                       FontSize="11" Foreground="#6C7086" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- SELECTION -->
        <Border Grid.Row="1" Background="#181825" CornerRadius="6"
                BorderBrush="#313244" BorderThickness="1" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="ROOF"
                           Style="{StaticResource SectionLabel}"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="DRAINS"
                           Style="{StaticResource SectionLabel}" Margin="8,8,0,4"/>

                <Border Grid.Row="1" Grid.Column="0"
                        Background="#313244" CornerRadius="4" Padding="8,6">
                    <TextBlock Text="{Binding RoofDescription}" FontSize="11"
                               Foreground="#CDD6F4" TextTrimming="CharacterEllipsis"/>
                </Border>

                <Button Grid.Row="1" Grid.Column="1" Content="Select Roof"
                        Command="{Binding SelectRoofCommand}"
                        Style="{StaticResource RevitButton}" Margin="8,0,16,0"/>

                <Border Grid.Row="1" Grid.Column="2"
                        Background="#313244" CornerRadius="4" Padding="8,6" Margin="8,0,0,0">
                    <TextBlock FontSize="11" Foreground="#CDD6F4">
                        <Run Text="{Binding DrainCount, StringFormat={}{0}}"/>
                        <Run Text=" drain point(s) selected"/>
                    </TextBlock>
                </Border>

                <Button Grid.Row="1" Grid.Column="3" Content="Select Drains"
                        Command="{Binding SelectDrainsCommand}"
                        Style="{StaticResource RevitButton}" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- SETTINGS -->
        <Border Grid.Row="2" Background="#181825" CornerRadius="6"
                BorderBrush="#313244" BorderThickness="1" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Proximity Distance (mm):"
                           VerticalAlignment="Center" Foreground="#CDD6F4" FontSize="12"/>
                <TextBox Grid.Column="1" Style="{StaticResource InputBox}" Margin="8,0,0,0"
                         Text="{Binding ProximityDistanceMm, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"/>

                <TextBlock Grid.Column="3" Text="Validation Tolerance (mm):"
                           VerticalAlignment="Center" Foreground="#CDD6F4" FontSize="12"/>
                <TextBox Grid.Column="4" Style="{StaticResource InputBox}" Margin="8,0,0,0"
                         Text="{Binding ValidationToleranceMm, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>

                <Button Grid.Column="6" Content="▶  Generate Ridges"
                        Command="{Binding RunCommand}"
                        Style="{StaticResource AccentButton}" Margin="12,0,0,0"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
            </Grid>
        </Border>

        <!-- PROGRESS -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,14"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ProgressDetail}" FontSize="10"
                       Foreground="#F9E2AF" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ProgressBar IsIndeterminate="True" Width="100" Height="6"
                         Foreground="#89B4FA" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- LOG TABS: Validation + Pipeline Log -->
        <Border Grid.Row="3" Background="#181825" CornerRadius="6"
                BorderBrush="#313244" BorderThickness="1" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header bar: summary counts + copy button -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Foreground="#A6E3A1" FontSize="11" VerticalAlignment="Center">
                        <Run Text="PASS: "/><Run Text="{Binding PassCount}"/>
                    </TextBlock>
                    <TextBlock Foreground="#F38BA8" FontSize="11"
                               Margin="16,0,0,0" VerticalAlignment="Center">
                        <Run Text="FAIL: "/><Run Text="{Binding FailCount}"/>
                    </TextBlock>
                    <TextBlock Foreground="#89B4FA" FontSize="11"
                               Margin="16,0,0,0" VerticalAlignment="Center"
                               Text="{Binding GroupCountDisplay, StringFormat='Groups: {0}'}"/>
                    <Button Content="📋 Copy Full Log"
                            Command="{Binding CopyLogCommand}"
                            Style="{StaticResource RevitButton}"
                            Margin="16,0,0,0" Padding="8,4"
                            VerticalAlignment="Center" FontSize="11"
                            ToolTip="Copies pipeline log + validation table to clipboard (paste into Notepad or Excel)"/>
                </StackPanel>

                <!-- Tab control -->
                <TabControl Grid.Row="1" Background="#181825" BorderBrush="#313244">

                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Background"  Value="#313244"/>
                            <Setter Property="Foreground"  Value="#CDD6F4"/>
                            <Setter Property="FontSize"    Value="11"/>
                            <Setter Property="FontWeight"  Value="SemiBold"/>
                            <Setter Property="Padding"     Value="10,4"/>
                            <Setter Property="BorderBrush" Value="#45475A"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#89B4FA"/>
                                    <Setter Property="Foreground" Value="#1E1E2E"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Resources>

                    <!-- TAB 1: Validation table -->
                    <TabItem Header="Validation Log">
                        <DataGrid Style="{StaticResource RidgeGrid}"
                                  ItemsSource="{Binding ValidationLog}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserSortColumns="True"
                                  SelectionMode="Single"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader"
                                       BasedOn="{StaticResource RidgeGridHeader}"/>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Pt #"       Binding="{Binding PointIndex}"                   Width="40"/>
                                <DataGridTextColumn Header="X (ft)"     Binding="{Binding X,            StringFormat=F4}" Width="72"/>
                                <DataGridTextColumn Header="Y (ft)"     Binding="{Binding Y,            StringFormat=F4}" Width="72"/>
                                <DataGridTextColumn Header="Max Δ (ft)" Binding="{Binding MaxDeviation, StringFormat=F6}" Width="85"/>
                                <DataGridTextColumn Header="Tol (ft)"   Binding="{Binding Tolerance,    StringFormat=F6}" Width="75"/>
                                <DataGridTextColumn Header="Result"     Binding="{Binding Passed}"                        Width="60"/>
                                <DataGridTextColumn Header="Note"       Binding="{Binding Note}"                          Width="*"/>
                            </DataGrid.Columns>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Passed}" Value="False">
                                            <Setter Property="Background" Value="#3B1E2E"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Passed}" Value="True">
                                            <Setter Property="Background" Value="#1E2E1E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </TabItem>

                    <!-- TAB 2: Full pipeline log — selectable TextBox so Ctrl+A / Ctrl+C work -->
                    <TabItem Header="Pipeline Log">
                        <TextBox Text="{Binding PipelineLogText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 FontFamily="Consolas, Courier New"
                                 FontSize="11"
                                 Foreground="#CDD6F4"
                                 Background="#11111B"
                                 BorderThickness="0"
                                 Padding="8"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 ToolTip="Select All: Ctrl+A   Copy: Ctrl+C"/>
                    </TabItem>

                </TabControl>
            </Grid>
        </Border>

        <!-- STATUS BAR -->
        <Border Grid.Row="4" Background="#181825" CornerRadius="4"
                BorderBrush="#313244" BorderThickness="1" Padding="8,4">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                       Foreground="#CDD6F4" TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>