<mah:MetroWindow
    x:Class="Revit26_Plugin.RoofTools.LineAndPoints.RoofRidgeLines.V64.Views.RoofRidgeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:conv="clr-namespace:Revit26_Plugin.RoofTools.LineAndPoints.RoofRidgeLines.V64.Converters"
    xmlns:shared="clr-namespace:Revit26_Plugin.Shared.Models"
    mc:Ignorable="d"
    Title="Roof Ridge Tool"
    TitleCharacterCasing="Normal"
    Width="1050" Height="750" MinWidth="950" MinHeight="650"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource BrushSystemBackground}">

    <mah:MetroWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Revit26_Plugin;component/Shared/SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:InverseBoolConverter        x:Key="InverseBool"/>
            <shared:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:ZeroToVisibilityConverter   x:Key="ZeroToVis"/>
        </ResourceDictionary>
    </mah:MetroWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="24,20,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ════════════════ LEFT COLUMN ════════════════ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Voronoi Ridge Generation" FontSize="20" FontWeight="Bold" Foreground="{StaticResource BrushNavyPrimary}"/>
                    <TextBlock Text="Select inner loops as drainage seeds to compute ridges." FontSize="12" Margin="0,4,0,0" Opacity="0.7" TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource AppIdentityCard}" Margin="0,0,0,16" Padding="12">
                    <StackPanel>
                        <TextBlock Text="1. BASE ROOF SELECTION" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource BrushSystemSecondaryBackground}" CornerRadius="4" Padding="8,8">
                                <TextBlock Text="{Binding RoofDescription}" Style="{StaticResource FieldValue}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </Border>
                            <Button Grid.Column="1" Content="Pick Roof" Command="{Binding SelectRoofCommand}" Style="{StaticResource OutlineButton}" Margin="8,0,0,0" Width="90"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource AppIdentityCard}" Margin="0,0,0,16" Padding="14">
                    <StackPanel>
                        <TextBlock Text="3. ALGORITHM CONFIGURATION" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Proximity Distance (mm)" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Style="{StaticResource BoxedTextInput}" Text="{Binding ProximityDistanceMm, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" HorizontalContentAlignment="Right"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Validation Tolerance (mm)" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Style="{StaticResource BoxedTextInput}" Text="{Binding ValidationToleranceMm, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" HorizontalContentAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- spacer row 3 keeps Generate pinned to bottom of the column -->

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ProgressDetail}" FontSize="11" Foreground="{StaticResource BrushWarning}" TextTrimming="CharacterEllipsis"/>
                        <ProgressBar IsIndeterminate="True" Height="4" Margin="0,4,0,0" Foreground="{StaticResource BrushNavyPrimary}"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="Generate Ridges" Command="{Binding RunCommand}" Style="{StaticResource PrimaryButton}" Width="160" Height="36" FontSize="13" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                </Grid>
            </Grid>

            <!-- ════════════════ RIGHT COLUMN ════════════════ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Metric cards -->
                <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,16">
                    <Border Style="{StaticResource MetricCard}" Margin="0,0,4,0" Padding="12,8">
                        <StackPanel>
                            <TextBlock Text="SELECTED SEEDS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource BrushNavyPrimary}"/>
                            <TextBlock Text="{Binding TotalCalculatedPoints}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource BrushNavyPrimary}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}" Margin="4,0,4,0" Padding="12,8">
                        <StackPanel>
                            <TextBlock Text="ADDED" FontSize="10" FontWeight="Bold" Foreground="{StaticResource BrushSuccess}"/>
                            <TextBlock Text="{Binding TotalAddedPoints}" FontSize="22" FontWeight="Light" Foreground="{StaticResource BrushSuccess}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}" Margin="4,0,0,0" Padding="12,8">
                        <StackPanel>
                            <TextBlock Text="FAILED" FontSize="10" FontWeight="Bold" Foreground="{StaticResource BrushDanger}"/>
                            <TextBlock Text="{Binding TotalFailedPoints}" FontSize="22" FontWeight="Light" Foreground="{StaticResource BrushDanger}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Grouped drainage seeds -->
                <Border Grid.Row="1" Style="{StaticResource ContentCard}" Margin="0,0,0,16" Padding="12,10">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="2. DRAINAGE SEEDS (INNER LOOPS)" Style="{StaticResource SectionTitle}" Margin="0"/>
                            <Border Grid.Column="1" Style="{StaticResource BadgePill}">
                                <TextBlock Style="{StaticResource BadgeText}">
                                    <Run Text="{Binding SelectedOpeningsCount, Mode=OneWay}"/><Run Text=" selected"/>
                                </TextBlock>
                            </Border>
                        </Grid>

                        <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- ── Circles ── -->
                                <Expander IsExpanded="True" Margin="0,0,0,8">
                                    <Expander.Header>
                                        <Grid Width="330">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Circles" FontWeight="SemiBold" FontSize="12.5" Foreground="{StaticResource BrushNavyPrimary}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11" Foreground="{StaticResource BrushTextSecondary}">
                                                <Run Text="("/><Run Text="{Binding CircleSelectedCount, Mode=OneWay}"/><Run Text="/"/><Run Text="{Binding CircleTotalCount, Mode=OneWay}"/><Run Text=" selected)"/>
                                            </TextBlock>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Content="All"  Command="{Binding SelectAllCirclesCommand}"  Style="{StaticResource SmallSecondaryButton}" Margin="0,0,4,0"/>
                                                <Button Content="None" Command="{Binding SelectNoneCirclesCommand}" Style="{StaticResource SmallSecondaryButton}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Expander.Header>
                                    <StackPanel Margin="0,4,0,0">
                                        <ItemsControl ItemsSource="{Binding CircleOpenings}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="6,5" Margin="0,1" CornerRadius="4"
                                                            Background="{StaticResource BrushSystemSecondaryBackground}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="2,0,8,0"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding DisplayDimensions}" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource BrushTextPrimary}"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding DisplayBBoxWidth}" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource BrushTextSecondary}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="No circular openings"
                                                   FontSize="11.5" FontStyle="Italic" Foreground="{StaticResource BrushTextTertiary}"
                                                   Margin="4,4,0,2"
                                                   Visibility="{Binding CircleTotalCount, Converter={StaticResource ZeroToVis}}"/>
                                    </StackPanel>
                                </Expander>

                                <!-- ── Rectangles ── -->
                                <Expander IsExpanded="True" Margin="0,0,0,8">
                                    <Expander.Header>
                                        <Grid Width="330">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Rectangles" FontWeight="SemiBold" FontSize="12.5" Foreground="{StaticResource BrushNavyPrimary}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11" Foreground="{StaticResource BrushTextSecondary}">
                                                <Run Text="("/><Run Text="{Binding RectangleSelectedCount, Mode=OneWay}"/><Run Text="/"/><Run Text="{Binding RectangleTotalCount, Mode=OneWay}"/><Run Text=" selected)"/>
                                            </TextBlock>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Content="All"  Command="{Binding SelectAllRectanglesCommand}"  Style="{StaticResource SmallSecondaryButton}" Margin="0,0,4,0"/>
                                                <Button Content="None" Command="{Binding SelectNoneRectanglesCommand}" Style="{StaticResource SmallSecondaryButton}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Expander.Header>
                                    <StackPanel Margin="0,4,0,0">
                                        <ItemsControl ItemsSource="{Binding RectangleOpenings}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="6,5" Margin="0,1" CornerRadius="4"
                                                            Background="{StaticResource BrushSystemSecondaryBackground}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="2,0,8,0"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding DisplayDimensions}" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource BrushTextPrimary}"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding DisplayBBoxWidth}" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource BrushTextSecondary}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="No rectangular openings"
                                                   FontSize="11.5" FontStyle="Italic" Foreground="{StaticResource BrushTextTertiary}"
                                                   Margin="4,4,0,2"
                                                   Visibility="{Binding RectangleTotalCount, Converter={StaticResource ZeroToVis}}"/>
                                    </StackPanel>
                                </Expander>

                                <!-- ── Others ── -->
                                <Expander IsExpanded="True">
                                    <Expander.Header>
                                        <Grid Width="330">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Others" FontWeight="SemiBold" FontSize="12.5" Foreground="{StaticResource BrushNavyPrimary}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11" Foreground="{StaticResource BrushTextSecondary}">
                                                <Run Text="("/><Run Text="{Binding OtherSelectedCount, Mode=OneWay}"/><Run Text="/"/><Run Text="{Binding OtherTotalCount, Mode=OneWay}"/><Run Text=" selected)"/>
                                            </TextBlock>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Content="All"  Command="{Binding SelectAllOthersCommand}"  Style="{StaticResource SmallSecondaryButton}" Margin="0,0,4,0"/>
                                                <Button Content="None" Command="{Binding SelectNoneOthersCommand}" Style="{StaticResource SmallSecondaryButton}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Expander.Header>
                                    <StackPanel Margin="0,4,0,0">
                                        <ItemsControl ItemsSource="{Binding OtherOpenings}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="6,5" Margin="0,1" CornerRadius="4"
                                                            Background="{StaticResource BrushSystemSecondaryBackground}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="2,0,8,0"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding DisplayDimensions}" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource BrushTextPrimary}"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding DisplayBBoxWidth}" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource BrushTextSecondary}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="No other openings"
                                                   FontSize="11.5" FontStyle="Italic" Foreground="{StaticResource BrushTextTertiary}"
                                                   Margin="4,4,0,2"
                                                   Visibility="{Binding OtherTotalCount, Converter={StaticResource ZeroToVis}}"/>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>

                        <TextBlock Margin="4,8,0,0" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource BrushNavyPrimary}">
                            <Run Text="Selected: "/><Run Text="{Binding SelectedOpeningsCount, Mode=OneWay}"/><Run Text=" opening(s) as seeds"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Log tabs -->
                <Border Grid.Row="2" Style="{StaticResource ContentCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="12,6">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontSize="11" Foreground="{StaticResource BrushSuccess}" FontWeight="SemiBold">
                                    <Run Text="PASS: "/><Run Text="{Binding PassCount}"/>
                                </TextBlock>
                                <TextBlock FontSize="11" Margin="16,0,0,0" Foreground="{StaticResource BrushDanger}" FontWeight="SemiBold">
                                    <Run Text="FAIL: "/><Run Text="{Binding FailCount}"/>
                                </TextBlock>
                                <TextBlock FontSize="11" Margin="16,0,0,0" Foreground="{StaticResource BrushNavyPrimary}" Opacity="0.8">
                                    <Run Text="{Binding GroupCountDisplay, StringFormat='Groups: {0}'}"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Content="Copy Log" Command="{Binding CopyLogCommand}" Style="{StaticResource SmallSecondaryButton}" HorizontalAlignment="Right"/>
                        </Grid>

                        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BrushSeparatorThin}">
                            <TabControl.Resources>
                                <Style TargetType="TabItem">
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="16,6"/>
                                </Style>
                            </TabControl.Resources>

                            <TabItem Header="Validation Log">
                                <DataGrid Style="{StaticResource StandardDataGrid}" ItemsSource="{Binding ValidationLog}" AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="True" SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Pt #" Binding="{Binding PointIndex}" Width="50"/>
                                        <DataGridTextColumn Header="X (ft)" Binding="{Binding X, StringFormat=F3}" Width="80"/>
                                        <DataGridTextColumn Header="Y (ft)" Binding="{Binding Y, StringFormat=F3}" Width="80"/>
                                        <DataGridTextColumn Header="Max &#916; (ft)" Binding="{Binding MaxDeviation, StringFormat=F5}" Width="90"/>
                                        <DataGridTextColumn Header="Tol (ft)" Binding="{Binding Tolerance, StringFormat=F5}" Width="80"/>
                                        <DataGridTextColumn Header="Result" Binding="{Binding Passed}" Width="65"/>
                                        <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*"/>
                                    </DataGrid.Columns>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow" BasedOn="{StaticResource StandardDataGridRow}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Passed}" Value="False">
                                                    <Setter Property="Background" Value="#FFF2F2"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Passed}" Value="True">
                                                    <Setter Property="Background" Value="#F2FBF4"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                </DataGrid>
                            </TabItem>

                            <TabItem Header="Pipeline Log">
                                <TextBox Text="{Binding PipelineLogText, Mode=OneWay}"
                                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                                         FontFamily="Consolas, Monaco, Courier New" FontSize="11.5"
                                         Foreground="{StaticResource BrushLogText}" Background="{StaticResource BrushLogBg}"
                                         Padding="10" BorderThickness="0"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource BrushSystemSecondaryBackground}" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BrushSeparatorThin}" Padding="16,6">
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource FieldLabel}" FontSize="11" TextTrimming="CharacterEllipsis" Opacity="0.8"/>
        </Border>
    </Grid>
</mah:MetroWindow>
