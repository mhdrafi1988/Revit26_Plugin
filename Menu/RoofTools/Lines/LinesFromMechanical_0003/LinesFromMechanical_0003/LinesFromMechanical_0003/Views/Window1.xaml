<Window x:Class="Revit26_Plugin.LinesFromMechanical.V003.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Revit26_Plugin.LinesFromMechanical.V003.Views"
        Title="Create Linked Mechanical Elements" 
        Height="750" Width="700"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <local:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- View Status -->
        <Border Grid.Row="0" Background="LightGray" Padding="5" Margin="0,0,0,10" CornerRadius="3">
            <TextBlock Text="{Binding ActiveViewName}" FontWeight="Bold"/>
        </Border>

        <!-- Warning Panel -->
        <Border Grid.Row="1" Background="Orange" Padding="5" Margin="0,0,0,10" CornerRadius="3"
                Visibility="{Binding ShowViewWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding ViewWarning}" TextWrapping="Wrap" Foreground="Black"/>
        </Border>

        <!-- Mode Selection -->
        <GroupBox Grid.Row="2" Header="Creation Mode" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="5">
                <RadioButton Content="Create Detail Lines" 
                             IsChecked="{Binding IsDetailLineMode}"
                             GroupName="CreationMode"
                             Margin="0,0,15,0"
                             IsEnabled="{Binding IsNotProcessing}"/>
                <RadioButton Content="Create Floors" 
                             IsChecked="{Binding IsFloorMode}"
                             GroupName="CreationMode"
                             Margin="0,0,15,0"
                             IsEnabled="{Binding IsNotProcessing}"/>
            </StackPanel>
        </GroupBox>

        <!-- Settings Panel -->
        <GroupBox Grid.Row="3" Header="Settings" Margin="0,0,0,10">
            <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="5">
                    <!-- Link Selection -->
                    <TextBlock Text="Select Link:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <ComboBox ItemsSource="{Binding AvailableLinks}" 
                              SelectedItem="{Binding SelectedLink}"
                              DisplayMemberPath="Name"
                              IsEnabled="{Binding IsNotProcessing}"/>

                    <!-- Family Selection -->
                    <TextBlock Text="Select Family:" FontWeight="Bold" Margin="0,10,0,2"/>
                    <ComboBox ItemsSource="{Binding AvailableFamilies}" 
                              SelectedItem="{Binding SelectedFamily}"
                              IsEnabled="{Binding IsNotProcessing}"
                              IsSynchronizedWithCurrentItem="True"/>

                    <!-- Radius -->
                    <TextBlock Text="Radius (mm):" FontWeight="Bold" Margin="0,10,0,2"/>
                    <TextBox Text="{Binding RadiusMm, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsNotProcessing}"/>

                    <!-- Color Selection (Detail Lines Mode only) -->
                    <StackPanel Visibility="{Binding IsDetailLineMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Circle Color:" FontWeight="Bold" Margin="0,10,0,2"/>
                        <ComboBox ItemsSource="{Binding ColorOptions}" 
                                  SelectedItem="{Binding SelectedColorOption}"
                                  DisplayMemberPath="Name"
                                  IsEnabled="{Binding IsNotProcessing}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="20" Height="20" Margin="0,0,5,0">
                                            <Rectangle.Fill>
                                                <SolidColorBrush Color="{Binding Color}"/>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Floor Type Selection (Floors Mode only) -->
                    <StackPanel Visibility="{Binding IsFloorMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Floor Family:" FontWeight="Bold" Margin="0,10,0,2"/>
                        <ComboBox ItemsSource="{Binding AvailableFloorFamilies}" 
                                  SelectedItem="{Binding SelectedFloorFamily}"
                                  DisplayMemberPath="Name"
                                  IsEnabled="{Binding IsNotProcessing}"/>

                        <TextBlock Text="Floor Type:" FontWeight="Bold" Margin="0,10,0,2"/>
                        <ComboBox ItemsSource="{Binding AvailableFloorTypes}" 
                                  SelectedItem="{Binding SelectedFloorType}"
                                  DisplayMemberPath="Name"
                                  IsEnabled="{Binding IsNotProcessing}"/>

                        <TextBlock Text="Offset from Level (mm):" FontWeight="Bold" Margin="0,10,0,2"/>
                        <TextBox Text="{Binding FloorOffsetMm, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsNotProcessing}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </GroupBox>

        <!-- Preview Panel -->
        <Border Grid.Row="4" Background="LightBlue" Padding="5" Margin="0,0,0,10" CornerRadius="3"
                Visibility="{Binding ShowPreviewCount, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding PreviewCount, StringFormat='Preview: {0} elements will be processed'}"
                       FontWeight="Bold"/>
        </Border>

        <!-- Warning for missing floor types -->
        <Border Grid.Row="5" Background="Orange" Padding="5" Margin="0,0,0,10" CornerRadius="3"
                Visibility="{Binding ShowNoFloorTypeWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="WARNING: No active floor types found in document. Please activate a floor type to use Floor creation mode."
                       TextWrapping="Wrap" Foreground="Black"/>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Top">
            <Button Content="Highlight" 
                    Command="{Binding HighlightCommand}"
                    Width="100" Height="30" Margin="0,0,5,0"
                    IsEnabled="{Binding CanProcess}"/>
            <Button Content="Process" 
                    Command="{Binding ProcessCommand}"
                    Width="100" Height="30" Margin="0,0,5,0"
                    Background="Green" Foreground="White"
                    IsEnabled="{Binding CanProcess}"/>
            <Button Content="Cancel" 
                    Command="{Binding CancelCommand}"
                    Width="100" Height="30"
                    IsEnabled="{Binding IsNotProcessing}"/>
        </StackPanel>

        <!-- Log Panel -->
        <GroupBox Grid.Row="7" Header="Log" Margin="0,0,0,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListBox ItemsSource="{Binding LogMessages}" 
                         Grid.Row="0"
                         FontFamily="Consolas" FontSize="11"
                         Margin="0,0,0,5"
                         Height="150"/>
                <Button Content="Copy Log" 
                        Command="{Binding CopyLogCommand}"
                        Grid.Row="1"
                        HorizontalAlignment="Right"
                        Width="80" Height="25"
                        Margin="0,5,0,0"/>
            </Grid>
        </GroupBox>

        <!-- Progress Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="8" 
                Background="#CCFFFFFF"
                Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Processing..." 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center"
                       FontSize="20" FontWeight="Bold"/>
        </Border>
    </Grid>
</Window>