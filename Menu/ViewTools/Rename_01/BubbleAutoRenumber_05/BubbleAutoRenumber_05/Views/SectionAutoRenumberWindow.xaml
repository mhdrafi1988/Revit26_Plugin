<Window x:Class="Revit26_Plugin.SectionAutoRenumber.Views.SectionAutoRenumberWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Section Auto Renumber"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Revit26_Plugin;component/Shared/SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </Window.Resources>

    <StackPanel Margin="12,12,12,12"
                Background="{StaticResource BrushSystemSecondaryBackground}">

        <!-- ── Identity card ─────────────────────────────────────────── -->
        <Border Style="{StaticResource AppIdentityCard}">
            <StackPanel Orientation="Horizontal">
                <Border Width="36" Height="36" CornerRadius="8"
                        Background="{StaticResource BrushInfo}"
                        Margin="0,0,12,0">
                    <TextBlock Text="⟳"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Section Auto Renumber" Style="{StaticResource AppName}"/>
                    <TextBlock Text="WAMI · Revit 2026"     Style="{StaticResource AppSubtitle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Sheet + Options card ──────────────────────────────────── -->
        <Border Style="{StaticResource ContentCard}">
            <StackPanel>

                <TextBlock Text="SHEET" Style="{StaticResource SectionTitle}"/>

                <!-- Sheet picker -->
                <StackPanel Style="{StaticResource FieldRow}" Orientation="Horizontal">
                    <TextBlock Text="Select sheet" Style="{StaticResource FieldLabel}"
                               VerticalAlignment="Center" Width="130"/>
                    <ComboBox ItemsSource="{Binding Sheets}"
                              SelectedItem="{Binding SelectedSheet}"
                              DisplayMemberPath="SheetNumber"
                              MinWidth="180"/>
                </StackPanel>

                <Border Style="{StaticResource SeparatorLine}"/>

                <!-- Starting number -->
                <StackPanel Style="{StaticResource FieldRow}" Orientation="Horizontal">
                    <TextBlock Text="Starting number" Style="{StaticResource FieldLabel}"
                               VerticalAlignment="Center" Width="130"/>
                    <TextBox Text="{Binding StartingNumber, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource StyledTextInput}"
                             Width="80"/>
                </StackPanel>

                <Border Style="{StaticResource SeparatorLine}"/>

                <!-- Threshold -->
                <StackPanel Style="{StaticResource FieldRow}" Orientation="Horizontal">
                    <TextBlock Text="Vertical threshold" Style="{StaticResource FieldLabel}"
                               VerticalAlignment="Center" Width="130"/>
                    <TextBox Text="{Binding VerticalThreshold, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource StyledTextInput}"
                             Width="80"/>
                    <TextBlock Text="mm" Style="{StaticResource UnitLabel}"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ── Sections grid card ────────────────────────────────────── -->
        <Border Style="{StaticResource ContentCard}">
            <StackPanel>

                <TextBlock Text="SECTIONS ON SHEET" Style="{StaticResource SectionTitle}"/>

                <DataGrid ItemsSource="{Binding SectionRows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource BrushSeparatorThin}"
                          CanUserSortColumns="False"
                          CanUserResizeRows="False"
                          CanUserResizeColumns="False"
                          SelectionMode="Single"
                          MaxHeight="220"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                          RowStyle="{StaticResource DataGridRowStyle}"
                          CellStyle="{StaticResource DataGridCellStyle}"
                          AlternationCount="2"
                          BorderThickness="0"
                          Background="Transparent"
                          Margin="0">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Current #"
                                            Binding="{Binding CurrentNumber}"
                                            Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding"           Value="8,5"/>
                                    <Setter Property="FontSize"          Value="11"/>
                                    <Setter Property="FontWeight"        Value="Medium"/>
                                    <Setter Property="Foreground"        Value="{StaticResource BrushTextSecondary}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="View name"
                                            Binding="{Binding ViewName}"
                                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding"           Value="8,5"/>
                                    <Setter Property="FontSize"          Value="11"/>
                                    <Setter Property="Foreground"        Value="{StaticResource BrushTextPrimary}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource BrushTextTertiary}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                    </DataGrid.Columns>
                </DataGrid>

            </StackPanel>
        </Border>

        <!-- ── Results card — hidden until first run ─────────────────── -->
        <Border Style="{StaticResource ContentCard}"
                Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>

                <TextBlock Text="LAST RUN" Style="{StaticResource SectionTitle}"/>

                <!-- Metrics -->
                <Grid Margin="12,4,12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Total"   Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding TotalCount}"
                                       Style="{StaticResource MetricNumberAccent}"/>
                            <TextBlock Text="views"   Style="{StaticResource MetricUnit}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Success" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding SuccessCount}"
                                       Style="{StaticResource MetricNumberSuccess}"/>
                            <TextBlock Text="renamed" Style="{StaticResource MetricUnit}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Failed"  Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding FailedCount}"
                                       Foreground="{StaticResource BrushDanger}"
                                       Style="{StaticResource MetricNumber}"/>
                            <TextBlock Text="skipped" Style="{StaticResource MetricUnit}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Height="0.5"
                        Background="{StaticResource BrushSeparatorThin}"
                        Margin="0"/>

                <!-- Log -->
                <Border Background="{StaticResource BrushLogBg}"
                        CornerRadius="0,0,10,10"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="LOG"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushLogTextDim}"
                                   Margin="0,0,0,6"/>
                        <ScrollViewer MaxHeight="160"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding LogText}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       LineHeight="18"
                                       Foreground="{StaticResource BrushLogText}"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <!-- ── Renumber button ────────────────────────────────────────── -->
        <Button Content="Renumber"
                Command="{Binding RunCommand}"
                Style="{StaticResource PrimaryButton}"
                Margin="0,4,0,0"/>

    </StackPanel>
</Window>
