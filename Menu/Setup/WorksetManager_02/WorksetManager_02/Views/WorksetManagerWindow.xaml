<Window x:Class="Revit26_Plugin.WorksetManager_02.Views.WorksetManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:Revit26_Plugin.WorksetManager_02.Helpers"
        Title="Workset Manager 02 — Link Workset Analyser"
        Height="780" Width="1100"
        MinHeight="560" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>

        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <h:InverseBooleanConverter   x:Key="InverseBool"/>

        <!-- Colours -->
        <SolidColorBrush x:Key="BgDeep"    Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BgCard"    Color="#2A2A3E"/>
        <SolidColorBrush x:Key="BgRow"     Color="#313148"/>
        <SolidColorBrush x:Key="Accent"    Color="#7C6AF5"/>
        <SolidColorBrush x:Key="AccentHov" Color="#9B8FF7"/>
        <SolidColorBrush x:Key="GreenOk"   Color="#4CAF50"/>
        <SolidColorBrush x:Key="OrangeWarn" Color="#FF9800"/>
        <SolidColorBrush x:Key="RedErr"    Color="#FF4C4C"/>
        <SolidColorBrush x:Key="TextPri"   Color="#E8E8F0"/>
        <SolidColorBrush x:Key="TextSec"   Color="#9090A8"/>
        <SolidColorBrush x:Key="BorderCol" Color="#3D3D5C"/>

        <!-- Primary button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHov}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button (darker) -->
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background"  Value="#3D3D5C"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Padding"     Value="10,4"/>
        </Style>

        <!-- Action button (green) -->
        <Style x:Key="ActionBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#2E7D32"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#43A047"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Section label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextPri}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>

        <!-- Sub-label -->
        <Style x:Key="SubLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSec}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <!-- Summary value -->
        <Style x:Key="SumVal" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextPri}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="MinWidth"    Value="40"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>

        <!-- Summary key -->
        <Style x:Key="SumKey" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSec}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Global DataGrid style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground"               Value="{StaticResource TextPri}"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderCol}"/>
            <Setter Property="RowBackground"            Value="{StaticResource BgCard}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BgRow}"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserDeleteRows"        Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="SelectionMode"            Value="Extended"/>
            <Setter Property="SelectionUnit"            Value="FullRow"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#3D3D5C"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPri}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderCol}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="26"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding"          Value="6,3"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground"               Value="{StaticResource TextPri}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Foreground"      Value="{StaticResource Accent}"/>
            <Setter Property="Background"      Value="{StaticResource BgRow}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="3"/>
        </Style>

    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header + toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Progress -->
            <RowDefinition Height="*"/>     <!-- Three grids -->
            <RowDefinition Height="Auto"/>  <!-- Summary -->
            <RowDefinition Height="Auto"/>  <!-- Log -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ══ Header + toolbar ══════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Workset Manager 02"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPri}"/>
                <TextBlock Text="Analyse and manage linked-file worksets"
                           FontSize="11" Foreground="{StaticResource TextSec}"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="▶  Analyse"
                    Command="{Binding AnalyseCommand}"
                    IsEnabled="{Binding IsAnalysing, Converter={StaticResource InverseBool}}"
                    Style="{StaticResource PrimaryBtn}"
                    VerticalAlignment="Center"
                    Padding="18,8"/>
        </Grid>

        <!-- ══ Progress bar ══════════════════════════════════════════════════ -->
        <ProgressBar Grid.Row="1"
                     IsIndeterminate="{Binding IsAnalysing}"
                     Visibility="{Binding IsAnalysing, Converter={StaticResource BoolToVis}}"
                     Margin="0,0,0,8"/>

        <!-- ══ Three grids ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>   <!-- Grid 1 -->
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>   <!-- Grid 2 -->
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>   <!-- Grid 3 -->
            </Grid.RowDefinitions>

            <!-- ── Grid 1 — Exact matches (read-only) ──────────────────────── -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgCard}"
                    CornerRadius="8"
                    BorderBrush="{StaticResource BorderCol}"
                    BorderThickness="1"
                    Padding="10,8">
                <DockPanel>
                    <!-- Header row -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <StackPanel DockPanel.Dock="Left" Orientation="Vertical">
                            <TextBlock Style="{StaticResource SectionLabel}">
                                ✔  Grid 1 — Exact Matches
                                <Run Foreground="{StaticResource TextSec}" FontSize="11" FontWeight="Normal">
                                    (read-only — no action needed)
                                </Run>
                            </TextBlock>
                            <TextBlock Style="{StaticResource SubLabel}"
                                       Text="Linked files with a matching workset AND all instances already assigned correctly."/>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid ItemsSource="{Binding ExactMatches}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Linked File"
                                                Binding="{Binding LinkedFileName}"
                                                Width="*" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Matched Workset"
                                                Binding="{Binding MatchedWorkset}"
                                                Width="220"/>
                            <DataGridTextColumn Header="Instances"
                                                Binding="{Binding InstanceCount}"
                                                Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- ── Grid 2 — Actionable links (reassign) ────────────────────── -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgCard}"
                    CornerRadius="8"
                    BorderBrush="#5C4A9A"
                    BorderThickness="1"
                    Padding="10,8">
                <DockPanel>
                    <!-- Header + selection toolbar -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <StackPanel DockPanel.Dock="Left" Orientation="Vertical">
                            <TextBlock Style="{StaticResource SectionLabel}">
                                ⚠  Grid 2 — Actionable Links
                                <Run Foreground="{StaticResource TextSec}" FontSize="11" FontWeight="Normal">
                                    (workset found but instances misassigned)
                                </Run>
                            </TextBlock>
                            <TextBlock Style="{StaticResource SubLabel}"
                                       Text="Check rows and click Reassign to move instances to their matching workset."/>
                        </StackPanel>

                        <!-- Selection + action buttons -->
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top"
                                    Margin="10,0,0,0">
                            <Button Content="Select All"
                                    Command="{Binding SelectAllGrid2Command}"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,4,0"/>
                            <Button Content="Select None"
                                    Command="{Binding SelectNoneGrid2Command}"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,4,0"/>
                            <Button Content="Invert"
                                    Command="{Binding InvertGrid2Command}"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,12,0"/>
                            <Button Content="⟳  Reassign Checked"
                                    Command="{Binding ReassignCheckedCommand}"
                                    Style="{StaticResource ActionBtn}"
                                    Padding="12,4"/>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid x:Name="Grid2"
                              ItemsSource="{Binding ActionableLinks}"
                              PreviewKeyDown="Grid2_PreviewKeyDown">
                        <DataGrid.Columns>
                            <!-- Checkbox column — IsReadOnly=False so template is interactive -->
                            <DataGridTemplateColumn Header="" Width="36" IsReadOnly="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay,
                                                              UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Linked File"
                                                Binding="{Binding LinkedFileName}"
                                                Width="*" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Matched Workset"
                                                Binding="{Binding MatchedWorkset}"
                                                Width="220"/>
                            <DataGridTextColumn Header="Total Inst."
                                                Binding="{Binding TotalInstances}"
                                                Width="75"/>
                            <DataGridTextColumn Header="On Correct WS"
                                                Binding="{Binding InstancesOnCorrectWorkset}"
                                                Width="95"/>
                            <DataGridTextColumn Header="Need Reassign"
                                                Binding="{Binding InstancesOnWrongWorkset}"
                                                Width="95"/>
                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding AssignmentStatus}"
                                                Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- ── Grid 3 — Unmatched links (create + assign) ──────────────── -->
            <Border Grid.Row="4"
                    Background="{StaticResource BgCard}"
                    CornerRadius="8"
                    BorderBrush="#7A3A3A"
                    BorderThickness="1"
                    Padding="10,8">
                <DockPanel>
                    <!-- Header + selection toolbar -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <StackPanel DockPanel.Dock="Left" Orientation="Vertical">
                            <TextBlock Style="{StaticResource SectionLabel}">
                                ✘  Grid 3 — Unmatched Links
                                <Run Foreground="{StaticResource TextSec}" FontSize="11" FontWeight="Normal">
                                    (no matching workset found)
                                </Run>
                            </TextBlock>
                            <TextBlock Style="{StaticResource SubLabel}"
                                       Text="Check rows and click Create &amp; Assign to create the workset and assign instances."/>
                        </StackPanel>

                        <!-- Selection + action buttons -->
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top"
                                    Margin="10,0,0,0">
                            <Button Content="Select All"
                                    Command="{Binding SelectAllGrid3Command}"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,4,0"/>
                            <Button Content="Select None"
                                    Command="{Binding SelectNoneGrid3Command}"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,4,0"/>
                            <Button Content="Invert"
                                    Command="{Binding InvertGrid3Command}"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,12,0"/>
                            <Button Content="＋  Create &amp; Assign"
                                    Command="{Binding CreateAndAssignCheckedCommand}"
                                    Style="{StaticResource ActionBtn}"
                                    Padding="12,4"/>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid x:Name="Grid3"
                              ItemsSource="{Binding UnmatchedLinks}"
                              PreviewKeyDown="Grid3_PreviewKeyDown">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="36" IsReadOnly="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay,
                                                              UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Linked File"
                                                Binding="{Binding LinkedFileName}"
                                                Width="*" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Proposed Workset"
                                                Binding="{Binding ProposedWorkset}"
                                                Width="220"/>
                            <DataGridTextColumn Header="Instances"
                                                Binding="{Binding InstanceCount}"
                                                Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ══ Summary panel ═════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{StaticResource BgCard}"
                CornerRadius="8"
                BorderBrush="{StaticResource BorderCol}"
                BorderThickness="1"
                Margin="0,8,0,0"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Column A -->
                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="Summary" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource Accent}" Margin="0,0,0,6"/>

                    <DockPanel Margin="0,2">
                        <TextBlock DockPanel.Dock="Left"  Style="{StaticResource SumKey}"
                                   Text="Total Links Found"/>
                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource SumVal}"
                                   Text="{Binding TotalLinksFound}"/>
                    </DockPanel>
                    <DockPanel Margin="0,2">
                        <TextBlock DockPanel.Dock="Left"  Style="{StaticResource SumKey}"
                                   Text="Matching Worksets Found"/>
                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource SumVal}"
                                   Text="{Binding TotalMatchingWorksetsFound}"/>
                    </DockPanel>
                    <DockPanel Margin="0,2">
                        <TextBlock DockPanel.Dock="Left"  Style="{StaticResource SumKey}"
                                   Text="Exact (no action needed)"/>
                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource SumVal}"
                                   Foreground="{StaticResource GreenOk}"
                                   Text="{Binding TotalExactMatches}"/>
                    </DockPanel>
                </StackPanel>

                <!-- Column B -->
                <StackPanel Grid.Column="1" Orientation="Vertical">
                    <TextBlock Text="Instances" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource Accent}" Margin="0,0,0,6"/>

                    <DockPanel Margin="0,2">
                        <TextBlock DockPanel.Dock="Left"  Style="{StaticResource SumKey}"
                                   Text="Total Instances Found"/>
                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource SumVal}"
                                   Text="{Binding TotalInstancesFound}"/>
                    </DockPanel>
                    <DockPanel Margin="0,2">
                        <TextBlock DockPanel.Dock="Left"  Style="{StaticResource SumKey}"
                                   Text="Assigned to Matching WS"/>
                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource SumVal}"
                                   Foreground="{StaticResource GreenOk}"
                                   Text="{Binding TotalInstancesAssigned}"/>
                    </DockPanel>
                    <DockPanel Margin="0,2">
                        <TextBlock DockPanel.Dock="Left"  Style="{StaticResource SumKey}"
                                   Text="Not Assigned / Unmatched"/>
                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource SumVal}"
                                   Foreground="{StaticResource RedErr}"
                                   Text="{Binding TotalInstancesNotAssigned}"/>
                    </DockPanel>
                </StackPanel>

                <!-- Column C -->
                <StackPanel Grid.Column="2" Orientation="Vertical">
                    <TextBlock Text="Selection" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource Accent}" Margin="0,0,0,6"/>

                    <DockPanel Margin="0,2">
                        <TextBlock DockPanel.Dock="Left"  Style="{StaticResource SumKey}"
                                   Text="Grid 2 Checked (Reassign)"/>
                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource SumVal}"
                                   Foreground="{StaticResource OrangeWarn}"
                                   Text="{Binding TotalActionableChecked}"/>
                    </DockPanel>
                    <DockPanel Margin="0,2">
                        <TextBlock DockPanel.Dock="Left"  Style="{StaticResource SumKey}"
                                   Text="Grid 3 Checked (Create)"/>
                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource SumVal}"
                                   Foreground="{StaticResource OrangeWarn}"
                                   Text="{Binding TotalUnmatchedChecked}"/>
                    </DockPanel>
                    <DockPanel Margin="0,2">
                        <TextBlock DockPanel.Dock="Left"  Style="{StaticResource SumKey}"
                                   Text="Total Selected for Action"/>
                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource SumVal}"
                                   Foreground="{StaticResource Accent}"
                                   FontSize="14"
                                   Text="{Binding TotalSelectedForAction}"/>
                    </DockPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Log panel ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="{StaticResource BgCard}"
                CornerRadius="6"
                BorderBrush="{StaticResource BorderCol}"
                BorderThickness="1"
                Margin="0,6,0,0"
                MaxHeight="90"
                Padding="8,6">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBox Text="{Binding LogText, Mode=OneWay}"
                         IsReadOnly="True"
                         Background="Transparent"
                         Foreground="{StaticResource TextSec}"
                         BorderThickness="0"
                         FontSize="11"
                         FontFamily="Consolas"
                         TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- ══ Status bar ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="5"
                Background="{StaticResource BgCard}"
                CornerRadius="6"
                Margin="0,6,0,0"
                Padding="10,5">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource TextSec}"
                       FontSize="11"/>
        </Border>
    </Grid>
</Window>
