<Window x:Class="WorksetManager_01.Views.WorksetManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WorksetManager_01.ViewModels"
        xmlns:h="clr-namespace:WorksetManager_01.Helpers"
        Title="Workset Manager — WorksetManager_01"
        Height="620" Width="980"
        MinHeight="450" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <h:InverseBooleanConverter   x:Key="InverseBool"/>

        <!-- Colours -->
        <SolidColorBrush x:Key="BgDeep"     Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BgCard"     Color="#2A2A3E"/>
        <SolidColorBrush x:Key="BgRow"      Color="#313148"/>
        <SolidColorBrush x:Key="Accent"     Color="#7C6AF5"/>
        <SolidColorBrush x:Key="AccentHov"  Color="#9B8FF7"/>
        <SolidColorBrush x:Key="TextPri"    Color="#E8E8F0"/>
        <SolidColorBrush x:Key="TextSec"    Color="#9090A8"/>
        <SolidColorBrush x:Key="EmptyRed"   Color="#FF4C4C"/>
        <SolidColorBrush x:Key="BorderCol"  Color="#3D3D5C"/>

        <!-- Button style -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHov}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#3D3D5C"/>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background"    Value="{StaticResource BgRow}"/>
            <Setter Property="Foreground"    Value="{StaticResource TextPri}"/>
            <Setter Property="BorderBrush"   Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="8,5"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="CaretBrush"    Value="{StaticResource TextPri}"/>
        </Style>

        <!-- DataGrid style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"           Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground"           Value="{StaticResource TextPri}"/>
            <Setter Property="BorderThickness"      Value="0"/>
            <Setter Property="GridLinesVisibility"  Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderCol}"/>
            <Setter Property="RowBackground"        Value="{StaticResource BgCard}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BgRow}"/>
            <Setter Property="FontSize"             Value="12"/>
            <Setter Property="SelectionMode"        Value="Single"/>
            <Setter Property="AutoGenerateColumns"  Value="False"/>
            <Setter Property="CanUserAddRows"       Value="False"/>
            <Setter Property="CanUserDeleteRows"    Value="False"/>
            <Setter Property="IsReadOnly"           Value="True"/>
            <Setter Property="HeadersVisibility"    Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="#3D3D5C"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPri}"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="8,6"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderCol}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="28"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding TotalElements}" Value="0">
                    <Setter Property="Foreground" Value="{StaticResource EmptyRed}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <!-- CheckBox style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPri}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ProgressBar style -->
        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="Background" Value="{StaticResource BgRow}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"     Value="3"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Progress -->
            <RowDefinition Height="*"/>     <!-- DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Workset Manager"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPri}"/>
            <TextBlock Text="Analyse worksets in the active Revit document"
                       FontSize="11" Foreground="{StaticResource TextSec}"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <!-- ── Toolbar ────────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Scan button -->
            <Button Grid.Column="0"
                    Content="▶  Scan Worksets"
                    Command="{Binding ScanCommand}"
                    IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}"
                    Style="{StaticResource PrimaryBtn}"
                    Margin="0,0,8,0"/>

            <!-- Include linked toggle -->
            <CheckBox Grid.Column="1"
                      Content="Include Linked Models"
                      IsChecked="{Binding IncludeLinkedModels}"
                      Margin="0,0,16,0"
                      VerticalAlignment="Center"/>

            <!-- Search box -->
            <TextBox Grid.Column="2"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SearchBox}"
                     Margin="0,0,8,0">
                <TextBox.Resources>
                    <Style TargetType="TextBox" BasedOn="{StaticResource SearchBox}">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="  🔍  Filter by workset name or type…"
                                                           Foreground="#5C5C7A" FontSize="12"
                                                           Margin="4,0,0,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <!-- Clear search -->
            <Button Grid.Column="3"
                    Content="✕"
                    Command="{Binding ClearSearchCommand}"
                    Style="{StaticResource SecondaryBtn}"
                    Padding="8,6"
                    Margin="0,0,8,0"
                    ToolTip="Clear filter"/>

            <!-- Copy -->
            <Button Grid.Column="4"
                    Content="📋  Copy"
                    Command="{Binding CopyToClipboardCommand}"
                    Style="{StaticResource SecondaryBtn}"
                    Margin="0,0,8,0"
                    ToolTip="Copy filtered results to clipboard"/>

            <!-- Export Excel -->
            <Button Grid.Column="5"
                    Content="📊  Export Excel"
                    Command="{Binding ExportToExcelCommand}"
                    Style="{StaticResource SecondaryBtn}"
                    ToolTip="Export full summary to .xlsx"/>
        </Grid>

        <!-- ── Progress bar ───────────────────────────────────────────────── -->
        <ProgressBar Grid.Row="2"
                     IsIndeterminate="{Binding IsScanning}"
                     Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"
                     Margin="0,0,0,8"/>

        <!-- ── DataGrid ───────────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="{StaticResource BgCard}"
                CornerRadius="8"
                BorderBrush="{StaticResource BorderCol}"
                BorderThickness="1">
            <DataGrid ItemsSource="{Binding FilteredItems}"
                      SelectedItem="{Binding SelectedWorkset}"
                      Margin="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Workset Name"
                                        Binding="{Binding WorksetName}"
                                        Width="200"
                                        FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Elements"
                                        Binding="{Binding TotalElements}"
                                        Width="80"/>
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding StatusLabel}"
                                        Width="70"/>
                    <DataGridTextColumn Header="Editable"
                                        Binding="{Binding EditableLabel}"
                                        Width="70"/>
                    <DataGridTextColumn Header="Type Breakdown"
                                        Binding="{Binding TypeBreakdown}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ── Status bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="4"
                Background="{StaticResource BgCard}"
                CornerRadius="6"
                Margin="0,10,0,0"
                Padding="10,6">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource TextSec}"
                       FontSize="11"/>
        </Border>
    </Grid>
</Window>
