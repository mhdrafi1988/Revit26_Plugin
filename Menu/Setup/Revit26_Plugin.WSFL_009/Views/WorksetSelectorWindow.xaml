<mah:MetroWindow
    x:Class="Revit26_Plugin.WSFL_009.Views.WorksetSelectorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Revit26_Plugin.WSFL_009.Views"
    mc:Ignorable="d"
    Title="Create Worksets from Linked Files"
    Height="700"
    Width="1000"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize">

    <mah:MetroWindow.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </mah:MetroWindow.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="160"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Pattern Input Area -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Workset Pattern:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox Width="320"
                         Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,10,0"/>
                <TextBlock Text="Use {name} for link name"
                           VerticalAlignment="Center"
                           Opacity="0.6"/>
            </StackPanel>
            <TextBlock x:Name="PatternErrorText"
                       Text="{Binding PatternErrorMessage}"
                       Foreground="Red"
                       FontSize="11"
                       Margin="105,3,0,0"
                       Visibility="{Binding HasPatternError, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>

        <!-- Select All / None Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Select All" Width="100" Margin="0,0,8,0" Command="{Binding SelectAllCommand}"/>
            <Button Content="Select None" Width="100" Command="{Binding SelectNoneCommand}"/>
        </StackPanel>

        <!-- DataGrid with 5 Columns -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  SelectionMode="Extended"
                  Margin="0,0,0,10">

            <DataGrid.Resources>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasInstances}" Value="False">
                            <Setter Property="Foreground" Value="Gray"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsExistingWorkset}" Value="True">
                            <Setter Property="Foreground" Value="DimGray"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <!-- Column 1: Serial Number -->
                <DataGridTextColumn Header="#" 
                                    Binding="{Binding SerialNumber}"
                                    IsReadOnly="True"
                                    Width="50"/>

                <!-- Column 2: Checkbox -->
                <DataGridCheckBoxColumn Header="Create"
                                        Binding="{Binding IsSelected}"
                                        IsReadOnly="{Binding IsExistingWorkset}"
                                        Width="60"/>

                <!-- Column 3: Linked File Name -->
                <DataGridTemplateColumn Header="Linked File Name" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding LinkName}" 
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="⚠️" 
                                           Foreground="Orange"
                                           Visibility="{Binding HasInstances, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                           ToolTip="No instances found in document"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Column 4: Current Assigned Workset -->
                <DataGridTextColumn Header="Current Assigned Workset"
                                    Binding="{Binding CurrentWorksetName}"
                                    IsReadOnly="True"
                                    Width="200">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMixedWorkset}" Value="True">
                                    <Setter Property="Foreground" Value="OrangeRed"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Column 5: Proposed Workset Name -->
                <DataGridTextColumn Header="Proposed Workset Name"
                                    Binding="{Binding ProposedWorksetName}"
                                    IsReadOnly="True"
                                    Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="{Binding ProposedWorksetTooltip}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Live Log Panel -->
        <GroupBox Grid.Row="3"
                  Header="Live Log"
                  Margin="0,0,0,10">
            <ListBox ItemsSource="{Binding Log}"
                     FontFamily="Consolas"
                     FontSize="12"/>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Create Worksets"
                    Width="150"
                    Margin="0,0,8,0"
                    Command="{Binding CreateCommand}"
                    IsEnabled="{Binding IsCreateEnabled}"/>
            <Button Content="Close"
                    Width="90"
                    Command="{Binding CloseCommand}"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>