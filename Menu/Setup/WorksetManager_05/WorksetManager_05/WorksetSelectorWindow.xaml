<mah:MetroWindow
    x:Class="Revit26_Plugin.WorksetManager_06.Views.WorksetSelectorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:local="clr-namespace:Revit26_Plugin.WorksetManager_06.Views"
    xmlns:shared="clr-namespace:Revit26_Plugin.Shared.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Workset Manager 04"
    Height="820"
    Width="1060"
    MinHeight="640"
    MinWidth="860"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize">

    <mah:MetroWindow.Resources>
        <!-- Converters registered here (never in a shared ResourceDictionary) -->
        <shared:BoolToVisibilityConverter         x:Key="BoolToVis"/>
        <shared:InverseBoolToVisibilityConverter  x:Key="InvBoolToVis"/>
        <shared:LogLevelToColorConverter          x:Key="LogLevelToColor"/>
        <shared:MixedWorksetToColorConverter      x:Key="MixedToColor"/>

        <!-- ══ COLOR BRUSHES ══════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="BrushSystemBackground"          Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BrushSystemSecondaryBackground" Color="#F2F2F7"/>
        <SolidColorBrush x:Key="BrushSystemTertiaryBackground"  Color="#E5E5EA"/>
        <SolidColorBrush x:Key="BrushSeparator"                 Color="#E5E5EA"/>
        <SolidColorBrush x:Key="BrushSeparatorThin"             Color="#F2F2F7"/>
        <SolidColorBrush x:Key="BrushAppleBlue"                 Color="#0071E3"/>
        <SolidColorBrush x:Key="BrushTextPrimary"               Color="#1C1C1E"/>
        <SolidColorBrush x:Key="BrushTextSecondary"             Color="#8E8E93"/>
        <SolidColorBrush x:Key="BrushSuccess"                   Color="#34C759"/>
        <SolidColorBrush x:Key="BrushWarning"                   Color="#FF9F0A"/>
        <SolidColorBrush x:Key="BrushDanger"                    Color="#FF453A"/>
        <SolidColorBrush x:Key="BrushLogBg"                     Color="#1C1C1E"/>
        <SolidColorBrush x:Key="BrushLogTitleBar"               Color="#2C2C2E"/>
        <SolidColorBrush x:Key="BrushLogText"                   Color="#EBEBF5"/>
        <SolidColorBrush x:Key="BrushLogTextDim"                Color="#636366"/>
        <SolidColorBrush x:Key="BrushLogBorder"                 Color="#3A3A3C"/>

        <!-- ══ TYPOGRAPHY ════════════════════════════════════════════════════ -->
        <Style x:Key="AppName" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        </Style>

        <Style x:Key="AppSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="Margin"     Value="0,2,0,0"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="9"/>
            <Setter Property="Foreground"   Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Opacity"      Value="0.7"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        </Style>

        <!-- ══ CARDS ═════════════════════════════════════════════════════════ -->
        <Style x:Key="BaseCard" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BrushSystemBackground}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushSeparator}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="CornerRadius"    Value="10"/>
        </Style>

        <Style x:Key="AppIdentityCard" TargetType="Border" BasedOn="{StaticResource BaseCard}">
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin"  Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SectionCard" TargetType="Border" BasedOn="{StaticResource BaseCard}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin"  Value="0,0,0,8"/>
        </Style>

        <!-- ══ BADGE PILL ════════════════════════════════════════════════════ -->
        <Style x:Key="BadgePill" TargetType="Border">
            <Setter Property="CornerRadius"      Value="10"/>
            <Setter Property="Padding"           Value="7,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ══ INPUTS ════════════════════════════════════════════════════════ -->
        <Style x:Key="BorderlessTextInput" TargetType="TextBox">
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="FontWeight"               Value="Medium"/>
            <Setter Property="Foreground"               Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Padding"                  Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"               Value="{StaticResource BrushAppleBlue}"/>
        </Style>

        <!-- ══ BUTTONS ═══════════════════════════════════════════════════════ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height"          Value="38"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Background"      Value="{StaticResource BrushAppleBlue}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                Padding="18,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource BrushAppleBlue}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Small ghost button used inside the log title bar -->
        <Style x:Key="LogGhostButton" TargetType="Button">
            <Setter Property="Height"          Value="22"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="Normal"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource BrushLogTextDim}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushLogBorder}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="7,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource BrushLogText}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BrushLogTextDim}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ DATAGRID ══════════════════════════════════════════════════════ -->
        <Style x:Key="GridBase" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns"       Value="False"/>
            <Setter Property="CanUserAddRows"            Value="False"/>
            <Setter Property="CanUserDeleteRows"         Value="False"/>
            <Setter Property="HeadersVisibility"         Value="Column"/>
            <Setter Property="SelectionMode"             Value="Single"/>
            <Setter Property="GridLinesVisibility"       Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush"  Value="{StaticResource BrushSeparatorThin}"/>
            <Setter Property="Background"                Value="{StaticResource BrushSystemBackground}"/>
            <Setter Property="BorderThickness"           Value="0"/>
            <Setter Property="RowBackground"             Value="{StaticResource BrushSystemBackground}"/>
            <Setter Property="AlternatingRowBackground"  Value="{StaticResource BrushSystemSecondaryBackground}"/>
            <Setter Property="FontSize"                  Value="12"/>
        </Style>

        <Style x:Key="GridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{StaticResource BrushSystemSecondaryBackground}"/>
            <Setter Property="Foreground"      Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushSeparator}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding"           Value="8,0"/>
            <Setter Property="Foreground"        Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="FontSize"          Value="12"/>
        </Style>

        <Style x:Key="MonoCell" TargetType="TextBlock" BasedOn="{StaticResource CellText}">
            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>

        <Style x:Key="CurrentWorksetCell" TargetType="TextBlock" BasedOn="{StaticResource CellText}">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMixedWorkset}" Value="True">
                    <Setter Property="Foreground" Value="#FF6B00"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Background="{StaticResource BrushSystemSecondaryBackground}">
        <Grid.RowDefinitions>
            <!-- Row 0: App identity + pattern -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Three section grids -->
            <RowDefinition Height="*"/>
            <!-- Row 2: Live log -->
            <RowDefinition Height="110"/>
            <!-- Row 3: Footer buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ ROW 0 — App identity + pattern ══════════════════════════════ -->
        <Border Grid.Row="0"
                Style="{StaticResource AppIdentityCard}"
                Margin="12,12,12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Workset Manager 04"
                               Style="{StaticResource AppName}"/>
                    <TextBlock Text="WSFL-010 · Assigns each linked file to its own workset"
                               Style="{StaticResource AppSubtitle}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Pattern"
                                   Style="{StaticResource FieldLabel}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Border BorderBrush="{StaticResource BrushSeparator}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8,4">
                            <TextBox Width="260"
                                     Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource BorderlessTextInput}"
                                     ToolTip="Use {name} as a placeholder for the linked file name"/>
                        </Border>
                        <TextBlock Text="Use {name} for the link file name"
                                   Style="{StaticResource HintText}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                    <!-- Pattern error — uses BoolToVisibilityConverter so it actually shows -->
                    <TextBlock Text="{Binding PatternErrorMessage}"
                               Foreground="{StaticResource BrushDanger}"
                               FontSize="10"
                               Margin="72,3,0,0"
                               Visibility="{Binding HasPatternError, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ ROW 1 — Three section grids ═════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="12,8,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── GRID 1 — Already created & assigned ─────────────────── -->
            <Border Grid.Row="0" Style="{StaticResource SectionCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource BrushSystemSecondaryBackground}"
                            CornerRadius="10,10,0,0"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7"
                                     Fill="{StaticResource BrushSuccess}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0"/>
                            <TextBlock Text="Already created &amp; assigned"
                                       Style="{StaticResource SectionTitle}"
                                       VerticalAlignment="Center"/>
                            <Border Style="{StaticResource BadgePill}"
                                    Background="{StaticResource BrushSuccess}"
                                    Margin="8,0,0,0">
                                <TextBlock Text="{Binding Grid1Count}"
                                           FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                            <TextBlock Text="Exact match confirmed — read only"
                                       Style="{StaticResource HintText}"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Height="0.5"
                            Background="{StaticResource BrushSeparatorThin}"
                            VerticalAlignment="Bottom"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Grid1AssignedItems}"
                              Style="{StaticResource GridBase}"
                              ColumnHeaderStyle="{StaticResource GridColumnHeader}"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"
                                                Binding="{Binding SerialNumber}"
                                                Width="40"
                                                ElementStyle="{StaticResource CellText}"/>
                            <DataGridTemplateColumn Header="Linked file" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LinkName}"
                                                   Style="{StaticResource MonoCell}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Workset" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProposedWorksetName}"
                                                   Style="{StaticResource MonoCell}"
                                                   Foreground="{StaticResource BrushSuccess}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Instances"
                                                Binding="{Binding InstanceCount}"
                                                Width="80"
                                                ElementStyle="{StaticResource CellText}"/>
                            <DataGridTemplateColumn Header="Status" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10"
                                                Background="{StaticResource BrushSuccess}"
                                                Padding="7,2"
                                                HorizontalAlignment="Left"
                                                Margin="8,0">
                                            <TextBlock Text="Assigned"
                                                       FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ── GRID 2 — Needs workset ──────────────────────────────── -->
            <Border Grid.Row="1" Style="{StaticResource SectionCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource BrushSystemSecondaryBackground}"
                            CornerRadius="10,10,0,0"
                            Padding="12,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Ellipse Width="7" Height="7"
                                         Fill="{StaticResource BrushAppleBlue}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0"/>
                                <TextBlock Text="Linked files — workset not yet created"
                                           Style="{StaticResource SectionTitle}"
                                           VerticalAlignment="Center"/>
                                <Border Style="{StaticResource BadgePill}"
                                        Background="{StaticResource BrushAppleBlue}"
                                        Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Grid2Count}"
                                               FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Select all"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding SelectAllCommand}"
                                        Margin="0,0,6,0"/>
                                <Button Content="Select none"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding SelectNoneCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="0" Height="0.5"
                            Background="{StaticResource BrushSeparatorThin}"
                            VerticalAlignment="Bottom"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Grid2ActionableItems}"
                              Style="{StaticResource GridBase}"
                              ColumnHeaderStyle="{StaticResource GridColumnHeader}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"
                                                Binding="{Binding SerialNumber}"
                                                IsReadOnly="True"
                                                Width="40"
                                                ElementStyle="{StaticResource CellText}"/>
                            <DataGridTemplateColumn Header="Create" Width="56">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Linked file" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LinkName}"
                                                   Style="{StaticResource MonoCell}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Current workset" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding CurrentWorksetName}"
                                                   Style="{StaticResource CurrentWorksetCell}"
                                                   ToolTip="MIXED = instances assigned to more than one workset"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Proposed workset" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProposedWorksetName}"
                                                   Style="{StaticResource MonoCell}"
                                                   ToolTip="{Binding ProposedWorksetTooltip}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Instances"
                                                Binding="{Binding InstanceCount}"
                                                IsReadOnly="True"
                                                Width="80"
                                                ElementStyle="{StaticResource CellText}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ── GRID 3 — No instances ───────────────────────────────── -->
            <Border Grid.Row="2" Style="{StaticResource SectionCard}" Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource BrushSystemSecondaryBackground}"
                            CornerRadius="10,10,0,0"
                            Padding="12,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Ellipse Width="7" Height="7"
                                         Fill="{StaticResource BrushWarning}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0"/>
                                <TextBlock Text="No instances in model"
                                           Style="{StaticResource SectionTitle}"
                                           VerticalAlignment="Center"/>
                                <Border Style="{StaticResource BadgePill}"
                                        Background="{StaticResource BrushWarning}"
                                        Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Grid3Count}"
                                               FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="Workset will be created; assignment happens when link is loaded"
                                           Style="{StaticResource HintText}"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Grid 3 Select all / none -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Select all"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding SelectAllG3Command}"
                                        Margin="0,0,6,0"/>
                                <Button Content="Select none"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding SelectNoneG3Command}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="0" Height="0.5"
                            Background="{StaticResource BrushSeparatorThin}"
                            VerticalAlignment="Bottom"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Grid3NoInstanceItems}"
                              Style="{StaticResource GridBase}"
                              ColumnHeaderStyle="{StaticResource GridColumnHeader}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"
                                                Binding="{Binding SerialNumber}"
                                                IsReadOnly="True"
                                                Width="40"
                                                ElementStyle="{StaticResource CellText}"/>
                            <DataGridTemplateColumn Header="Create" Width="56">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Linked file" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LinkName}"
                                                   Style="{StaticResource MonoCell}"
                                                   Opacity="0.6"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Proposed workset" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProposedWorksetName}"
                                                   Style="{StaticResource MonoCell}"
                                                   Opacity="0.6"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Status" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10"
                                                Background="{StaticResource BrushSystemTertiaryBackground}"
                                                Padding="7,2"
                                                HorizontalAlignment="Left"
                                                Margin="8,0">
                                            <TextBlock Text="Unloaded / not placed"
                                                       FontSize="10"
                                                       Foreground="{StaticResource BrushTextSecondary}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ ROW 2 — Live log (bottom, above footer) ══════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushLogBg}"
                CornerRadius="10"
                Margin="12,8,12,0"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title bar with Copy Log button -->
                <Border Grid.Row="0"
                        Background="{StaticResource BrushLogTitleBar}"
                        CornerRadius="10,10,0,0"
                        Padding="10,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="LIVE LOG"
                                   FontFamily="Consolas"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushLogTextDim}"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Content="Copy log"
                                Style="{StaticResource LogGhostButton}"
                                Command="{Binding CopyLogCommand}"
                                ToolTip="Copy all log entries to clipboard"/>
                    </Grid>
                </Border>

                <!-- Log entries — level color wired via LogLevelToColorConverter -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Log}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Padding="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"    Value="0"/>
                            <Setter Property="Margin"     Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="10,1">
                                <TextBlock Text="{Binding Time, StringFormat=HH:mm:ss}"
                                           FontFamily="Consolas"
                                           FontSize="10"
                                           Foreground="{StaticResource BrushLogTextDim}"
                                           Width="58"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Level}"
                                           FontFamily="Consolas"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding Level, Converter={StaticResource LogLevelToColor}}"
                                           Width="60"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Message}"
                                           FontFamily="Consolas"
                                           FontSize="10"
                                           Foreground="{StaticResource BrushLogText}"
                                           TextWrapping="NoWrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ══ ROW 3 — Footer ════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{StaticResource BrushSystemBackground}"
                BorderBrush="{StaticResource BrushSeparatorThin}"
                BorderThickness="0,1,0,0"
                Padding="12,10"
                Margin="12,8,12,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{StaticResource BrushTextSecondary}">
                    <Run Text="{Binding TotalSelectedCount, Mode=OneWay}"/>
                    <Run Text=" link(s) selected for creation"/>
                </TextBlock>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Resync all"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ResyncCommand}"
                            IsEnabled="{Binding IsResyncEnabled}"
                            Margin="0,0,8,0"
                            ToolTip="Re-assign selected links to their matching worksets"/>
                    <Button Content="Create worksets"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding CreateCommand}"
                            IsEnabled="{Binding IsCreateEnabled}"
                            Margin="0,0,8,0"
                            ToolTip="Create worksets for selected Grid 2 &amp; Grid 3 links and assign instances"/>
                    <Button Content="Close"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding CloseCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>
